<% layout('layout') %>

<div class="space-y-4" id="schedule-root">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div>
      <h1 class="text-lg font-bold text-slate-800">Jadwal Stream</h1>
      <p class="text-slate-400 text-xs mt-0.5">Semua stream terjadwal dan rotasi aktif Anda</p>
    </div>
    <div class="flex items-center gap-2">
      <select id="view-range" onchange="loadSchedule()" class="appearance-none bg-white border border-slate-200 text-slate-700 text-xs px-3 py-1.5 pr-8 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary cursor-pointer">
        <option value="24">24 Jam ke Depan</option>
        <option value="48">48 Jam ke Depan</option>
        <option value="168" selected>7 Hari ke Depan</option>
      </select>
      <a href="/dashboard" class="flex items-center gap-1.5 bg-primary text-white text-xs px-3 py-1.5 rounded-lg hover:bg-secondary transition-colors">
        <i class="ti ti-plus text-sm"></i>
        Buat Stream
      </a>
    </div>
  </div>

  <!-- Stats Row (compact) -->
  <div class="grid grid-cols-4 gap-2">
    <div class="bg-white rounded-lg border border-slate-200 px-3 py-2.5 flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-calendar-event text-amber-500 text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none" id="stat-scheduled"><%= scheduledStreams.length %></div>
        <div class="text-[10px] text-slate-400 mt-0.5">Terjadwal</div>
      </div>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 px-3 py-2.5 flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-refresh text-emerald-500 text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none"><%= rotations.length %></div>
        <div class="text-[10px] text-slate-400 mt-0.5">Rotasi Aktif</div>
      </div>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 px-3 py-2.5 flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-lg bg-sky-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-clock text-primary text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none" id="stat-upcoming">—</div>
        <div class="text-[10px] text-slate-400 mt-0.5">Dalam 24 Jam</div>
      </div>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 px-3 py-2.5 flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-lg bg-red-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-broadcast text-red-500 text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none" id="stat-live">—</div>
        <div class="text-[10px] text-slate-400 mt-0.5">Live Sekarang</div>
      </div>
    </div>
  </div>

  <!-- Conflict Alert -->
  <div id="conflict-alert" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-3 flex items-start gap-3">
    <i class="ti ti-alert-triangle text-amber-500 text-base flex-shrink-0 mt-0.5"></i>
    <div>
      <div class="text-sm font-semibold text-amber-700">Potensi Konflik Jadwal</div>
      <div id="conflict-detail" class="text-xs text-amber-600 mt-0.5"></div>
    </div>
  </div>

  <!-- 2-column main content -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <!-- LEFT: Timeline (takes 2/3 width) -->
    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 overflow-hidden">
      <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-slate-800">Timeline Jadwal</h2>
          <p class="text-[11px] text-slate-400">Stream individual yang dijadwalkan</p>
        </div>
        <span class="text-xs text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full" id="timeline-count">Memuat...</span>
      </div>
      <div id="timeline-list" class="divide-y divide-slate-50">
        <div class="flex items-center justify-center py-10 text-slate-300">
          <i class="ti ti-loader animate-spin text-2xl"></i>
        </div>
      </div>
    </div>

    <!-- RIGHT: Rotations + quick info (takes 1/3 width) -->
    <div class="lg:col-span-1 space-y-4">

      <% if (rotations.length > 0) { %>
      <!-- Active Rotations -->
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
          <div>
            <h2 class="text-sm font-semibold text-slate-800">Rotasi Aktif</h2>
            <p class="text-[11px] text-slate-400"><%= rotations.length %> rotasi berjalan</p>
          </div>
          <a href="/rotations" class="text-xs text-primary hover:underline">Kelola →</a>
        </div>
        <div class="divide-y divide-slate-50">
          <% rotations.forEach(function(r) { %>
          <div class="flex items-center gap-3 px-3 py-2.5 hover:bg-slate-50 transition-colors">
            <!-- Status Dot -->
            <div class="flex-shrink-0 w-2 h-2 rounded-full <%= r.status === 'active' ? 'bg-emerald-400 animate-pulse' : 'bg-amber-400' %>"></div>
            <!-- Info -->
            <div class="flex-1 min-w-0">
              <div class="text-xs font-medium text-slate-800 truncate"><%= r.name %></div>
              <div class="text-[10px] text-slate-400 flex items-center gap-1 mt-0.5">
                <i class="ti ti-list-numbers"></i>
                <span><%= r.item_count %> item</span>
                <% if (r.start_time) { %>
                <span class="text-slate-200">•</span>
                <span><%= r.start_time ? r.start_time.replace('T',' ').slice(11,16) : '' %> → <%= r.end_time ? r.end_time.replace('T',' ').slice(11,16) : '' %></span>
                <% } %>
              </div>
            </div>
            <span class="flex-shrink-0 text-[10px] px-1.5 py-0.5 rounded-full font-medium
              <%= r.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
              <%= r.status === 'active' ? 'Aktif' : 'Terjeda' %>
            </span>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Quick Links Card -->
      <div class="bg-white rounded-xl border border-slate-200 p-4 space-y-2">
        <h3 class="text-sm font-semibold text-slate-700 mb-3">Aksi Cepat</h3>
        <a href="/dashboard" class="flex items-center gap-2.5 p-2.5 rounded-lg hover:bg-slate-50 transition-colors border border-slate-100 group">
          <div class="w-7 h-7 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
            <i class="ti ti-plus text-primary text-sm"></i>
          </div>
          <div>
            <div class="text-xs font-medium text-slate-800">Buat Stream Baru</div>
            <div class="text-[10px] text-slate-400">Dari Dashboard utama</div>
          </div>
        </a>
        <a href="/rotations" class="flex items-center gap-2.5 p-2.5 rounded-lg hover:bg-slate-50 transition-colors border border-slate-100 group">
          <div class="w-7 h-7 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-100 transition-colors">
            <i class="ti ti-rotate text-emerald-500 text-sm"></i>
          </div>
          <div>
            <div class="text-xs font-medium text-slate-800">Kelola Tugas Live</div>
            <div class="text-[10px] text-slate-400">Atur rotasi dan item stream</div>
          </div>
        </a>
        <a href="/schedule" class="flex items-center gap-2.5 p-2.5 rounded-lg hover:bg-slate-50 transition-colors border border-slate-100 group" onclick="document.getElementById('view-range').value='168';loadSchedule();return false;">
          <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0 group-hover:bg-amber-100 transition-colors">
            <i class="ti ti-calendar-week text-amber-500 text-sm"></i>
          </div>
          <div>
            <div class="text-xs font-medium text-slate-800">Lihat 7 Hari ke Depan</div>
            <div class="text-[10px] text-slate-400">Semua jadwal minggu ini</div>
          </div>
        </a>
      </div>

    </div><!-- end right col -->
  </div><!-- end 2-col grid -->

</div>


</div>

<style>
  .timeline-item { transition: background 0.15s; }
  .timeline-item:hover { background: #f8fafc; }
  .platform-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
</style>

<script>
(function() {
  function fmtDT(str) {
    if (!str) return '—';
    try {
      const d = new Date(str);
      return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) + ' ' +
             d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
    } catch(e) { return str; }
  }

  function timeUntil(str) {
    if (!str) return '';
    const diff = new Date(str) - new Date();
    if (diff < 0) return '<span class="text-red-500">Terlambat</span>';
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    if (h > 24) return `${Math.floor(h/24)} hari lagi`;
    if (h > 0) return `${h}j ${m}m lagi`;
    return `${m} menit lagi`;
  }

  function platformColor(p) {
    const map = { YouTube: '#ff0000', Facebook: '#1877f2', Twitch: '#9146ff', TikTok: '#000', Instagram: '#e1306c', Custom: '#64748b' };
    return map[p] || '#64748b';
  }

  async function loadStats() {
    try {
      const r = await fetch('/api/analytics/stream-stats');
      const d = await r.json();
      if (d.success) {
        document.getElementById('stat-live').textContent = d.live;
      }
    } catch(e) {}
  }

  async function loadSchedule() {
    const hours = document.getElementById('view-range').value;
    const list = document.getElementById('timeline-list');
    const countEl = document.getElementById('timeline-count');
    const upcoming24El = document.getElementById('stat-upcoming');

    list.innerHTML = '<div class="flex items-center justify-center py-12 text-slate-300"><i class="ti ti-loader animate-spin text-2xl"></i></div>';

    try {
      const r = await fetch(`/api/schedule/upcoming?hours=${hours}`);
      const d = await r.json();

      if (!d.success || d.streams.length === 0) {
        list.innerHTML = `<div class="flex flex-col items-center justify-center py-16 text-slate-300">
          <i class="ti ti-calendar-off text-4xl mb-3"></i>
          <p class="text-sm">Tidak ada jadwal dalam ${hours} jam ke depan</p>
          <a href="/dashboard" class="mt-3 text-xs text-primary hover:underline">+ Buat Stream Baru</a>
        </div>`;
        countEl.textContent = '0 jadwal';
        return;
      }

      countEl.textContent = `${d.streams.length} jadwal`;
      upcoming24El.textContent = d.streams.length;

      // Check for conflicts (same stream key)
      const keyMap = {};
      const conflicts = [];
      d.streams.forEach(s => {
        if (s.stream_key) {
          if (keyMap[s.stream_key]) {
            conflicts.push(`"${s.title}" dan "${keyMap[s.stream_key]}" menggunakan stream key yang sama`);
          } else {
            keyMap[s.stream_key] = s.title;
          }
        }
      });
      if (conflicts.length > 0) {
        document.getElementById('conflict-alert').classList.remove('hidden');
        document.getElementById('conflict-detail').textContent = conflicts.join('; ');
      } else {
        document.getElementById('conflict-alert').classList.add('hidden');
      }

      list.innerHTML = d.streams.map(s => {
        const color = platformColor(s.platform);
        const videoName = s.video_title || s.playlist_name || s.title || '—';
        return `<div class="timeline-item flex items-center gap-4 px-4 py-3.5">
          <div class="flex-shrink-0 w-1 h-10 rounded-full" style="background:${color}"></div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-sm font-semibold text-slate-800 truncate">${s.title || 'Untitled'}</span>
              <span class="text-[10px] bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded-full font-medium">Terjadwal</span>
            </div>
            <div class="flex items-center gap-3 mt-0.5 text-xs text-slate-400 flex-wrap">
              <span class="flex items-center gap-1"><i class="ti ti-brand-${s.platform === 'YouTube' ? 'youtube' : 'broadcast'}"></i> ${s.platform || 'Custom'}</span>
              <span class="text-slate-200">•</span>
              <span class="flex items-center gap-1"><i class="ti ti-video"></i> ${videoName}</span>
              ${s.youtube_channel_name ? `<span class="text-slate-200">•</span><span>${s.youtube_channel_name}</span>` : ''}
            </div>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-xs font-semibold text-slate-700">${fmtDT(s.schedule_time)}</div>
            <div class="text-[11px] text-primary mt-0.5">${timeUntil(s.schedule_time)}</div>
          </div>
        </div>`;
      }).join('');
    } catch(e) {
      console.error(e);
      list.innerHTML = '<div class="py-12 text-center text-red-400 text-sm">Gagal memuat jadwal</div>';
    }
  }

  loadStats();
  loadSchedule();
})();
</script>
