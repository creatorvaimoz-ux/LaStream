          if (mode === 'copy') {
            resSection.classList.add('hidden');
            infoBox.innerHTML = '<i class="ti ti-leaf text-emerald-500 mt-0.5 flex-shrink-0"></i><p class="text-emerald-600 text-xs"><strong>Soft Copy</strong> — Video dikirim langsung tanpa re-encoding. Sangat ringan untuk CPU VPS. Resolusi & FPS mengikuti file sumber.</p>';
            infoBox.className = 'bg-emerald-50 border border-emerald-200 rounded-lg p-3 flex items-start gap-2';
          } else {
            resSection.classList.remove('hidden');
            const labels = { x264: 'Software x264 — Re-encode via CPU. Fleksibel tapi berat untuk VPS.', nvenc: 'NVIDIA NVENC — Re-encode via GPU NVIDIA. Ringan di CPU.', qsv: 'Intel QuickSync — Re-encode via Intel iGPU. Ringan di CPU.' };
            infoBox.innerHTML = '<i class="ti ti-info-circle text-sky-500 mt-0.5 flex-shrink-0"></i><p class="text-sky-700 text-xs"><strong>' + mode.toUpperCase() + '</strong> — ' + (labels[mode] || '') + '</p>';
