    <script>
      // Toggle Acak ±15 mnt options
      document.getElementById('pgRandomTime').addEventListener('change', function () {
        document.getElementById('pgRandomTimeOptions').classList.toggle('hidden', !this.checked);
      });
      // Toggle Smart Stop options
      document.getElementById('pgSmartStop').addEventListener('change', function () {
        document.getElementById('pgSmartStopOptions').classList.toggle('hidden', !this.checked);
      });
      
      // Toggle Output Type Mode (Manual vs Auto)
      function pgUpdateOutputMode() {
        const mode = document.getElementById('pgOutputType').value;
        const isManual = mode === 'rtmp';
        
        // Select all overlays and sections
        const overlays = ['pgMetadataOverlay', 'pgRandomOverlay', 'pgChatbotOverlay', 'pgThumbnailOverlay'];
        const sections = ['pgSectionMetadata', 'pgSectionRandom', 'pgSectionChatbot', 'pgSectionThumbnail'];
        
        overlays.forEach((id, index) => {
          const overlay = document.getElementById(id);
          const section = document.getElementById(sections[index]);
          if (overlay && section) {
            if (isManual) {
              overlay.classList.remove('hidden');
              section.style.pointerEvents = 'none';
            } else {
              overlay.classList.add('hidden');
              section.style.pointerEvents = 'auto';
            }
          }
        });
      }
      
      document.getElementById('pgOutputType').addEventListener('change', pgUpdateOutputMode);
      // Initialize on load
      pgUpdateOutputMode();
      
      // Chatbot toggle
      document.getElementById('pgEnableChatbot').addEventListener('change', function () {
        const section = document.getElementById('pgChatbotSection');
        if (this.checked) {
          section.style.opacity = '1';
          section.style.pointerEvents = 'auto';
        } else {
          section.style.opacity = '0.5';
          section.style.pointerEvents = 'none';
        }
      });

      // Tambah Jadwal Chatbot
      function pgAddChatbotTimeline() {
        const list = document.getElementById('pgChatbotList');
        const empty = document.getElementById('pgChatbotEmpty');
        if (empty) empty.style.display = 'none';

        const item = document.createElement('div');
        item.className = 'flex gap-2 items-start pg-chatbot-item';
        item.innerHTML = `
          <div class="w-24 flex-shrink-0">
            <div class="relative">
              <input type="number" min="1" placeholder="Menit" class="w-full px-2 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-xs focus:border-primary pr-8">
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[10px] text-slate-400">mnt</span>
            </div>
          </div>
          <div class="flex-1">
            <input type="text" placeholder="Ketik pesan otomatis untuk dikirim ke Live Chat..." class="w-full px-2 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-xs focus:border-primary">
          </div>
          <button type="button" onclick="this.parentElement.remove(); pgCheckChatbotEmpty();" class="mt-1 p-1 text-slate-400 hover:text-red-500 transition-colors">
            <i class="ti ti-x text-sm"></i>
          </button>
        `;
        list.appendChild(item);
      }

      function pgCheckChatbotEmpty() {
        const list = document.getElementById('pgChatbotList');
        const empty = document.getElementById('pgChatbotEmpty');
        const items = list.querySelectorAll('.pg-chatbot-item');
        if (items.length === 0) {
          empty.style.display = 'block';
        }
      }
    </script>

