                  const file = this.files[0];
                  const reader = new FileReader();
                  reader.onload = function(e) {
                    preview.innerHTML = `<img src="${e.target.result}" class="max-h-32 mx-auto rounded-lg object-contain mb-2"><p class="text-xs text-slate-600 font-medium">${file.name}</p>`;
                  }
                  reader.readAsDataURL(file);
                } else {
                  preview.innerHTML = `<i class="ti ti-files text-4xl text-primary mb-2"></i><p class="text-sm font-medium text-slate-700">${this.files.length} File terpilih</p><p class="text-[10px] text-slate-500 mt-1">Siap untuk diacak</p>`;
