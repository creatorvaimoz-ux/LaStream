                        </div>
                        <div>
                          <label class="text-xs text-slate-500 mb-1 flex items-center">
                            <span>End Time</span>
                            <span id="ytDurationBadge"
                              class="ml-2 bg-slate-100 text-xs text-slate-600 px-2 py-0.5 rounded hidden">00:00</span>
                          </label>
                          <input type="datetime-local" id="ytScheduleEnd" name="ytScheduleEnd"
                            class="w-full h-[42px] px-4 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary text-sm [color-scheme:dark]">
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

          </form>
        </div>
        <div class="flex-shrink-0 flex items-center justify-end gap-3 p-4 sm:px-6 sm:py-4 border-t border-slate-200">
