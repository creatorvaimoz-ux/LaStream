                          <div
                            class="absolute left-[2px] top-[2px] w-5 h-5 bg-white rounded-full transition-all peer-checked:translate-x-5">
                          </div>
                        </label>
                      </div>

                      <div class="h-[42px] flex items-center justify-between">
                        <div class="flex items-center gap-2">
                          <label class="text-sm text-slate-600">Enable Monetization</label>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                          <input type="checkbox" id="ytEnableMonetization" class="sr-only peer">
                          <div class="w-11 h-6 bg-slate-100 rounded-full peer peer-checked:bg-primary"></div>
                          <div
                            class="absolute left-[2px] top-[2px] w-5 h-5 bg-white rounded-full transition-all peer-checked:translate-x-5">
                          </div>
                        </label>
                      </div>

                      <div class="h-[42px] flex items-center justify-between">
