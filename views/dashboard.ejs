                          <label class="text-sm text-slate-600">Auto-Generated Subtitles</label>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                          <input type="checkbox" id="ytEnableClosedCaptions" class="sr-only peer">
                          <div class="w-11 h-6 bg-slate-100 rounded-full peer peer-checked:bg-primary"></div>
                          <div
