                                    <p class="text-xs text-slate-500">
                                      <%= Number(channel.subscriber_count || 0).toLocaleString() %> subs
                                    </p>
                                  </div>
                                  <% if (channel.is_default) { %>
                                    <span class="text-xs text-primary">Default</span>
                                    <% } %>
                                </button>
                                <% }); %>
                            </div>
                            <% } %>
