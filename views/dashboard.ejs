                                  <%= typeof youtubeSubscriberCount !=='undefined' ?
                                    Number(youtubeSubscriberCount).toLocaleString() : '0' %> subscribers
                                </p>
                              </div>
                            </div>
                            <% if (typeof youtubeChannels !=='undefined' && youtubeChannels.length> 1) { %>
                              <button type="button" onclick="toggleChannelSelector()"
