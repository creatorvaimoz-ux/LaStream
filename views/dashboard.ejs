                            <div id="channelSelectorDropdown"
                              class="hidden mt-3 pt-3 border-t border-slate-200 space-y-2">
                              <% youtubeChannels.forEach(function(channel) { %>
                                <button type="button"
                                  onclick="selectYtChannel('<%= channel.id %>', '<%= channel.channel_name %>', '<%= channel.channel_thumbnail %>', '<%= channel.subscriber_count %>')"
