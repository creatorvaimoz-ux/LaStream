<% layout('layout') -%>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Kelola dan jadwalkan live streaming YouTube Anda</p>
  </div>
</div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-3 sm:gap-5">
    <!-- ========== LEFT COLUMN ========== -->
    <div class="lg:col-span-3 space-y-3 sm:space-y-5">

      <!-- 1. Pengaturan Stream Umum -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-5 py-3 border-b border-slate-100 flex items-center gap-2">
          <i class="ti ti-settings text-primary"></i>
          <h3 class="font-semibold text-slate-800 text-sm">Pengaturan Stream Umum</h3>
        </div>
        <div class="p-4 sm:p-5 space-y-4">
          <div>
            <label class="text-xs text-slate-400 block mb-1">Nama Tugas Live</label>
            <input type="text" id="pgStreamTitle" placeholder="Contoh: Live Streaming Malam..."
              class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary placeholder-slate-500">
          </div>
          <div>
            <label class="text-xs text-slate-400 block mb-1">Pilih Video <span class="text-[10px] text-primary">(Bisa pilih > 1 untuk acak, gunakan Ctrl/Cmd)</span></label>
            <select id="pgVideoSelect" multiple size="4"
              class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary">
            </select>
          </div>
          <div>
            <label class="text-xs text-slate-400 block mb-1">Jenis Jalur Keluaran</label>
            <select id="pgOutputType" onchange="document.getElementById('pgManualRtmpSection').classList.toggle('hidden', this.value !== 'rtmp')"
              class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary">
              <option value="rtmp">Custom RTMP</option>
              <option value="youtube" selected>YouTube API v3 (Auto)</option>
            </select>
          </div>
          <div id="pgManualRtmpSection" class="hidden grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-slate-400 block mb-1">RTMP URL</label>
              <input type="text" id="pgRtmpUrl" placeholder="rtmps://a.rtmp.youtube.com/live2"
                class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary placeholder-slate-500">
            </div>
            <div>
              <label class="text-xs text-slate-400 block mb-1">Kunci Stream / Stream Key</label>
              <div class="relative">
                <input type="password" id="pgStreamKey" placeholder="Masukkan stream key..."
                  class="w-full px-3 py-2 pr-10 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary placeholder-slate-500">
                <button type="button"
                  onclick="this.previousElementSibling.type = this.previousElementSibling.type==='password'?'text':'password'"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-700"><i
                    class="ti ti-eye text-sm"></i></button>
              </div>
            </div>
          </div>
          <label class="flex items-center gap-2 text-xs text-slate-400 cursor-pointer">
            <input type="checkbox" id="pgLoopVideo" checked
              class="rounded border-slate-300 bg-white text-primary focus:ring-primary"> Video di-loop terus menerus
            selama jadwal aktif
          </label>
          <div class="bg-blue-50 border border-blue-100 rounded-lg p-3 flex items-start gap-2">
            <i class="ti ti-info-circle text-primary mt-0.5 flex-shrink-0"></i>
            <p class="text-blue-700 text-xs">Mode API: Isi cukup detail dibawah dan YouTube Studio akan mengatur
              broadcast key secara otomatis. Pastikan terhubung ke YouTube di menu Settings &rarr; Integrasi &amp; akun.
            </p>
          </div>
        </div>
      </div>

      <!-- 2. Metadata YouTube Studio -->
      <div id="pgSectionMetadata" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden transition-opacity duration-300 relative">
        <!-- Manual mode overlay -->
        <div id="pgMetadataOverlay" class="absolute inset-0 bg-white/60 z-10 hidden flex flex-col items-center justify-center backdrop-blur-[1px]">
          <div class="bg-slate-800 text-white text-xs px-3 py-1.5 rounded-full mb-1">Mode Manual Aktif</div>
          <p class="text-[10px] text-slate-600 font-medium">Pengaturan mengikuti YouTube Studio</p>
        </div>
        <div class="px-4 sm:px-5 py-3 border-b border-slate-100 flex items-center gap-2">
          <i class="ti ti-brand-youtube text-red-500"></i>
          <h3 class="font-semibold text-slate-800 text-sm">Metadata YouTube Studio</h3>
        </div>
        <div class="p-4 sm:p-5 space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-slate-400 block mb-1">Pilih Channel</label>
              <select id="pgChannel"
                class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary">
                <% if (typeof youtubeChannels !=='undefined' && youtubeChannels.length> 0) { %>
                  <% youtubeChannels.forEach(function(ch) { %>
                    <option value="<%= ch.id %>" <%=ch.is_default ? 'selected' : '' %>><%= ch.channel_name %>
                    </option>
                    <% }); %>
                      <% } else { %>
                        <option value="">— Belum terhubung —</option>
                        <% } %>
              </select>
            </div>
            <div>
              <label class="text-xs text-slate-400 block mb-1">Ketersediaan</label>
              <select id="pgPrivacy"
                class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary">
                <option value="public">Public</option>
                <option value="unlisted" selected>Unlisted</option>
                <option value="private">Private</option>
              </select>
            </div>
          </div>
          <div>
            <label class="text-xs text-slate-400 block mb-1">Judul Video untuk YouTube</label>
            <input type="text" id="pgYtTitle" placeholder="Judul default / custom untuk live..."
              class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary placeholder-slate-500">
          </div>
          <div>
            <label class="text-xs text-slate-400 block mb-1">Deskripsi</label>
            <textarea id="pgYtDesc" rows="3" placeholder="Deskripsi untuk video YouTube..."
              class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary placeholder-slate-500 resize-y"></textarea>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-slate-400 block mb-1">Kategori</label>
              <select id="pgCategory"
                class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary">
                <option value="22">People & Blogs</option>
                <option value="20">Gaming</option>
                <option value="24">Entertainment</option>
                <option value="10">Music</option>
                <option value="28">Science & Technology</option>
                <option value="27">Education</option>
              </select>
            </div>
            <div>
              <label class="text-xs text-slate-400 block mb-1">Tags</label>
              <input type="text" id="pgTags" placeholder="tag1, tag2, tag3..."
                class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-primary focus:ring-1 focus:ring-primary placeholder-slate-500">
            </div>
          </div>
          <label class="flex items-center gap-2 text-xs text-slate-500 cursor-pointer bg-slate-50 border border-slate-200 rounded-lg px-3 py-2.5 mt-2">
            <input type="checkbox" id="pgAutoSubtitles" class="rounded border-slate-300 text-primary">
            <div>
              <div class="font-medium text-slate-700">Auto-Generated Subtitles</div>
              <div class="text-[10px] text-slate-400">Aktifkan Closed Captions (Subtitles) otomatis dari YouTube</div>
            </div>
          </label>
          <p class="text-xs text-slate-500 mt-2">Default: metadata diambil dari nama file & pengaturan akun YouTube anda.</p>
        </div>
      </div>

      <!-- NEW: Content AI Generator (VidIQ-style) -->
      <div id="pgSectionAI" class="bg-white rounded-xl border border-violet-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-5 py-3 border-b border-violet-100 flex items-center justify-between cursor-pointer"
          onclick="document.getElementById('pgAISection').classList.toggle('hidden'); this.querySelector('.ai-chevron').classList.toggle('rotate-180')">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-lg bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center">
              <i class="ti ti-sparkles text-white text-sm"></i>
            </div>
            <h3 class="font-semibold text-slate-800 text-sm">Content AI</h3>
            <span class="text-[10px] bg-violet-100 text-violet-600 px-2 py-0.5 rounded-full font-medium">VidIQ-style</span>
          </div>
          <i class="ti ti-chevron-up text-violet-400 ai-chevron transition-transform duration-200"></i>
        </div>
        <div id="pgAISection" class="p-4 sm:p-5 space-y-4">
          <!-- Provider Selector -->
          <div class="flex gap-2">
            <button type="button" id="pgAIProviderGemini" onclick="pgSelectProvider('gemini')"
              class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg border-2 border-violet-500 bg-violet-50 text-violet-700 text-xs font-semibold transition-all">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              Gemini
            </button>
            <button type="button" id="pgAIProviderOpenAI" onclick="pgSelectProvider('openai')"
              class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg border-2 border-slate-200 bg-white text-slate-500 text-xs font-semibold transition-all hover:border-slate-300">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
              ChatGPT
            </button>
          </div>
          <!-- Alert jika belum set API key -->
          <div id="pgAINoKey" class="hidden bg-amber-50 border border-amber-200 rounded-lg p-3 flex items-start gap-2">
            <i class="ti ti-alert-triangle text-amber-500 mt-0.5 flex-shrink-0"></i>
            <p class="text-amber-700 text-xs">API Key belum dikonfigurasi. <a href="/settings" class="font-semibold underline">Buka Settings → AI Generator</a> untuk mengatur.</p>
          </div>
          <!-- Prompt Input -->
          <div>
            <label class="text-xs text-slate-400 block mb-1">Topik / Konteks Stream <span class="text-violet-500">*</span></label>
            <input type="text" id="pgAIPrompt" placeholder="Contoh: Mountain River Waterfall, Live musik Jazz malam, Tutorial Python..."
              class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-sm focus:border-violet-400 focus:ring-1 focus:ring-violet-400 placeholder-slate-400"
              onkeydown="if(event.key==='Enter') generateAIContent()">
          </div>

          <!-- Competitor Reference Title (collapsible) -->
          <div>
            <button type="button" onclick="pgToggleRefTitle()" class="flex items-center gap-1.5 text-[11px] text-violet-500 hover:text-violet-700 font-medium">
              <i class="ti ti-brand-youtube text-[12px]"></i>
              <span id="pgRefTitleToggleText">+ Tambah Judul Referensi Kompetitor</span>
            </button>
            <div id="pgRefTitleBox" class="hidden mt-1.5">
              <label class="text-xs text-slate-400 block mb-1">Judul Kompetitor <span class="text-[10px] text-slate-400">(opsional — AI akan analisis & tiru pola judul ini)</span></label>
              <textarea id="pgAIRefTitle" rows="2"
                placeholder="Contoh: Mountain River Waterfall Flowing 24/7. Water Sounds, Nature White Noise. River Sounds for Sleeping."
                class="w-full px-3 py-2 bg-orange-50 border border-orange-200 rounded-lg text-slate-700 text-xs focus:border-orange-400 focus:ring-1 focus:ring-orange-400 placeholder-slate-400 resize-none"></textarea>
              <p class="text-[10px] text-slate-400 mt-0.5">💡 AI akan analisis pola kata kunci, struktur, & panjang judul kompetitor lalu buat variasi yang lebih baik.</p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
            <div>
              <label class="text-xs text-slate-400 block mb-1">Bahasa</label>
              <select id="pgAILanguage" class="w-full px-2 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-xs focus:border-violet-400">
                <option value="auto">🌐 Auto Detect</option>
                <option value="id">🇮🇩 Indonesia</option>
                <option value="en">🇺🇸 English</option>
                <option value="es">🇪🇸 Spanish</option>
                <option value="ja">🇯🇵 Japanese</option>
                <option value="ko">🇰🇷 Korean</option>
                <option value="hi">🇮🇳 Hindi</option>
              </select>
            </div>
            <div>
              <label class="text-xs text-slate-400 block mb-1">Gaya</label>
              <select id="pgAIStyle" class="w-full px-2 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-xs focus:border-violet-400">
                <option value="casual">😄 Santai</option>
                <option value="professional">💼 Profesional</option>
                <option value="clickbait">🔥 Viral</option>
                <option value="educational">📚 Edukatif</option>
              </select>
            </div>
            <div>
              <label class="text-xs text-slate-400 block mb-1">Jumlah Judul</label>
              <select id="pgAITitleCount" class="w-full px-2 py-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 text-xs focus:border-violet-400">
                <option value="3" selected>3 Variasi</option>
                <option value="5">5 Variasi</option>
                <option value="7">7 Variasi</option>
                <option value="10">10 Variasi</option>
              </select>
            </div>
          </div>
          <button type="button" id="pgAIGenerate" onclick="generateAIContent()"
            class="w-full px-4 py-2.5 bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-700 hover:to-purple-700 text-white rounded-lg text-sm font-semibold transition-all flex items-center justify-center gap-2 shadow-sm">
            <i class="ti ti-sparkles" id="pgAIBtnIcon"></i>
            <span id="pgAIBtnText">✨ Generate dengan AI</span>

          </button>

          <!-- AI Result Panel (VidIQ-style) -->
          <div id="pgAIResult" class="hidden space-y-4 border-t border-violet-100 pt-4">
            <!-- SEO Score -->
            <div class="bg-gradient-to-r from-violet-50 to-purple-50 border border-violet-200 rounded-xl p-3">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2">
                  <i class="ti ti-chart-bar text-violet-600"></i>
                  <span class="text-xs font-bold text-violet-700">SEO Score</span>
                </div>
                <div class="flex items-center gap-1">
                  <span id="pgAISeoScore" class="text-2xl font-black text-violet-700">--</span>
                  <span class="text-xs text-violet-500">/100</span>
                </div>
              </div>
              <div class="w-full bg-violet-200 rounded-full h-2 mb-2">
                <div id="pgAISeoBar" class="h-2 rounded-full transition-all duration-700 bg-gradient-to-r from-violet-500 to-purple-500" style="width:0%"></div>
              </div>
              <div id="pgAISeoTips" class="space-y-1"></div>
            </div>

            <!-- Research Analysis -->
            <div id="pgAIResearchPanel" class="hidden bg-indigo-50 border border-indigo-200 rounded-xl p-3">
              <div class="flex items-center gap-2 mb-2">
                <i class="ti ti-microscope text-indigo-600"></i>
                <span class="text-xs font-bold text-indigo-800">Analisis Riset YouTube</span>
              </div>
              <p id="pgAIResearchText" class="text-[11px] text-indigo-700 leading-relaxed"></p>
            </div>

            <!-- Title Variants -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <label class="text-xs font-semibold text-slate-700 flex items-center gap-1">
                  <i class="ti ti-text-size text-violet-500"></i> Variasi Judul
                </label>
                <span class="text-[10px] text-slate-400">Klik untuk pilih</span>
              </div>
              <div id="pgAITitlesContainer" class="space-y-2"></div>
            </div>

            <!-- Description -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <label class="text-xs font-semibold text-slate-700 flex items-center gap-1">
                  <i class="ti ti-align-left text-violet-500"></i> Deskripsi SEO
                </label>
                <button type="button" onclick="pgApplyAI('desc')" class="text-[10px] text-violet-600 hover:text-violet-800 font-semibold flex items-center gap-1 hover:underline">
                  Terapkan <i class="ti ti-arrow-right text-[10px]"></i>
                </button>
              </div>
              <div id="pgAIDesc" class="w-full px-3 py-2.5 bg-violet-50 border border-violet-200 rounded-lg text-slate-700 text-xs min-h-[70px] whitespace-pre-wrap leading-relaxed"></div>
            </div>

            <!-- Tags Pill -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <label class="text-xs font-semibold text-slate-700 flex items-center gap-1">
                  <i class="ti ti-tags text-violet-500"></i> Tags <span id="pgAITagCount" class="text-[10px] text-slate-400"></span>
                </label>
                <button type="button" onclick="pgApplyAI('tags')" class="text-[10px] text-violet-600 hover:text-violet-800 font-semibold flex items-center gap-1 hover:underline">
                  Terapkan <i class="ti ti-arrow-right text-[10px]"></i>
                </button>
              </div>
              <div id="pgAITagsContainer" class="flex flex-wrap gap-1.5 mb-2"></div>
              <div id="pgAITagLegend" class="flex flex-wrap items-center gap-2 mt-1"></div>
            </div>

            <!-- Apply All Button -->
            <button type="button" onclick="pgApplyAI('all')"
              class="w-full px-4 py-2.5 bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-700 hover:to-purple-700 text-white rounded-lg text-sm font-bold transition-all flex items-center justify-center gap-2 shadow-md">
              <i class="ti ti-check"></i> Terapkan Semua ke Form
            </button>
          </div>

          <!-- Error Panel -->
          <div id="pgAIError" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 flex items-start gap-2">
            <i class="ti ti-alert-circle text-red-500 mt-0.5 flex-shrink-0"></i>
            <p id="pgAIErrorMsg" class="text-red-700 text-xs"></p>
          </div>
        </div>
      </div>

      <script>
        // AI State
        let pgAIProvider = 'gemini';
        let pgAIData = null;
        let pgSelectedTitleIndex = 0;
        let pgAITags = [];
        let pgAIDesc = '';

        function pgToggleRefTitle() {
          const box = document.getElementById('pgRefTitleBox');
          const txt = document.getElementById('pgRefTitleToggleText');
          const hidden = box.classList.contains('hidden');
          box.classList.toggle('hidden', !hidden);
          txt.textContent = hidden ? '− Sembunyikan Judul Referensi' : '+ Tambah Judul Referensi Kompetitor';
        }

        function pgSelectProvider(p) {
          pgAIProvider = p;
          document.getElementById('pgAIProviderGemini').className = p === 'gemini'
            ? 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg border-2 border-violet-500 bg-violet-50 text-violet-700 text-xs font-semibold transition-all'
            : 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg border-2 border-slate-200 bg-white text-slate-500 text-xs font-semibold transition-all hover:border-slate-300';
          document.getElementById('pgAIProviderOpenAI').className = p === 'openai'
            ? 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg border-2 border-violet-500 bg-violet-50 text-violet-700 text-xs font-semibold transition-all'
            : 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg border-2 border-slate-200 bg-white text-slate-500 text-xs font-semibold transition-all hover:border-slate-300';
        }

        // Check AI settings on load
        fetch('/api/settings/ai').then(r => r.json()).then(data => {
          if (data.success) {
            pgAIProvider = data.defaultProvider || 'gemini';
            pgSelectProvider(pgAIProvider);
            const hasKey = pgAIProvider === 'gemini' ? data.hasGemini : data.hasOpenAI;
            if (!data.hasGemini && !data.hasOpenAI) {
              document.getElementById('pgAINoKey').classList.remove('hidden');
            }
          }
        }).catch(() => {});

        async function generateAIContent() {
          const prompt = document.getElementById('pgAIPrompt').value.trim();
          if (!prompt) { document.getElementById('pgAIPrompt').focus(); return; }

          const btn = document.getElementById('pgAIGenerate');
          const btnText = document.getElementById('pgAIBtnText');
          const btnIcon = document.getElementById('pgAIBtnIcon');
          btn.disabled = true;
          btnText.textContent = 'Sedang Generate...';
          btnIcon.className = 'ti ti-loader animate-spin';
          document.getElementById('pgAIResult').classList.add('hidden');
          document.getElementById('pgAIError').classList.add('hidden');

          try {
            const csrfToken = window._csrfToken || 
                              document.querySelector('meta[name="csrf-token"]')?.content || 
                              document.querySelector('input[name="_csrf"]')?.value || '';
            const titleCount = document.getElementById('pgAITitleCount')?.value || '3';
            const refTitle = document.getElementById('pgAIRefTitle')?.value?.trim() || '';
            const targetLanguage = document.getElementById('pgAILanguage')?.value || 'auto';
            const res = await fetch('/api/ai/generate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
              body: JSON.stringify({
                prompt,
                style: document.getElementById('pgAIStyle').value,
                provider: pgAIProvider,
                titleCount,
                refTitle,
                targetLanguage
              })
            });
            const data = await res.json();
            if (!data.success) {
              if (data.quotaExceeded && pgAIProvider === 'gemini') {
                // Show quota error with switch suggestion
                document.getElementById('pgAIErrorMsg').innerHTML = 
                  `⚠️ ${data.error} <button onclick="pgSelectProvider('openai'); generateAIContent();" 
                   class="ml-1 px-2 py-0.5 bg-violet-600 text-white rounded text-[10px] font-bold hover:bg-violet-700">
                   Coba ChatGPT →</button>`;
              } else {
                throw new Error(data.error || 'Gagal generate.');
              }
              document.getElementById('pgAIError').classList.remove('hidden');
              return;
            }

            pgAIData = data;
            pgAITags = data.tags || [];
            pgAIDesc = data.description || '';
            pgSelectedTitleIndex = 0;
            pgRenderAIResult(data);
          } catch (err) {
            document.getElementById('pgAIErrorMsg').textContent = err.message;
            document.getElementById('pgAIError').classList.remove('hidden');
          } finally {
            btn.disabled = false;
            btnText.textContent = '✨ Generate dengan AI';
            btnIcon.className = 'ti ti-sparkles';
          }
        }

        function pgRenderAIResult(data) {
          // Offline mode notice
          let providerBadge = document.getElementById('pgAIProviderBadge');
          if (!providerBadge) {
            providerBadge = document.createElement('div');
            providerBadge.id = 'pgAIProviderBadge';
            document.getElementById('pgAIResult').prepend(providerBadge);
          }
          if (data.offline) {
            providerBadge.innerHTML = `<div class="bg-amber-50 border border-amber-200 rounded-lg p-2.5 flex items-center gap-2 mb-3">
              <i class="ti ti-wifi-off text-amber-500 flex-shrink-0"></i>
              <p class="text-amber-700 text-xs"><strong>Mode Template</strong> — Kuota API habis. Hasil ini dibuat dari template otomatis (bukan AI). Coba lagi nanti saat kuota reset.</p>
            </div>`;
          } else {
            providerBadge.innerHTML = `<div class="flex items-center gap-1.5 mb-2">
              <i class="ti ti-check text-green-500 text-xs"></i>
              <span class="text-[10px] text-slate-400">Generated by: ${data.provider || 'AI'}</span>
            </div>`;
          }

          // SEO Score
          const score = data.seoScore || 75;
          document.getElementById('pgAISeoScore').textContent = score;
          const bar = document.getElementById('pgAISeoBar');
          bar.style.width = '0%';
          setTimeout(() => { bar.style.width = score + '%'; }, 50);
          const color = score >= 80 ? 'from-green-500 to-emerald-500' : score >= 60 ? 'from-yellow-500 to-amber-500' : 'from-red-500 to-orange-500';
          bar.className = `h-2 rounded-full transition-all duration-700 bg-gradient-to-r ${color}`;

          // SEO Tips
          const tipsEl = document.getElementById('pgAISeoTips');
          tipsEl.innerHTML = (data.seoTips || []).map(t =>
            `<div class="flex items-center gap-1.5"><i class="ti ti-bulb text-amber-500 text-[11px]"></i><span class="text-[11px] text-violet-700">${t}</span></div>`
          ).join('');

          // Research Analysis
          const researchPanel = document.getElementById('pgAIResearchPanel');
          if (data.researchAnalysis) {
            document.getElementById('pgAIResearchText').textContent = data.researchAnalysis;
            researchPanel.classList.remove('hidden');
          } else {
            researchPanel.classList.add('hidden');
          }

          // Title Variants with SEO indicators
          const titlesEl = document.getElementById('pgAITitlesContainer');
          const refTitleVal = document.getElementById('pgAIRefTitle')?.value?.trim() || '';
          const isLongFormMode = refTitleVal.length > 67; // competitor uses long-form strategy
          titlesEl.innerHTML = (data.titles || []).map((title, i) => {
            const len = title.length;
            let lenColor, lenTip;
            if (isLongFormMode) {
              // Long-form: 80-120 is optimal
              lenColor = len >= 80 && len <= 120 ? 'text-green-600 bg-green-50 border-green-200' :
                         len >= 60 && len <= 140 ? 'text-amber-600 bg-amber-50 border-amber-200' :
                                                   'text-red-600 bg-red-50 border-red-200';
              lenTip = len >= 80 && len <= 120 ? '✓ Optimal (long-form)' : len < 80 ? '↑ Kurang panjang' : '↓ Terlalu panjang';
            } else {
              // Standard: 55-65 is optimal
              lenColor = len >= 55 && len <= 65 ? 'text-green-600 bg-green-50 border-green-200' :
                         len >= 45 && len <= 75 ? 'text-amber-600 bg-amber-50 border-amber-200' :
                                                   'text-red-600 bg-red-50 border-red-200';
              lenTip = len >= 55 && len <= 65 ? '✓ Optimal' : len < 55 ? '↑ Too short' : '↓ Too long';
            }
            return `
            <div class="pg-ai-title-item flex items-start gap-2 p-2.5 rounded-lg border-2 cursor-pointer transition-all ${i === 0 ? 'border-violet-500 bg-violet-50' : 'border-slate-200 bg-white hover:border-violet-300'}"
              onclick="pgSelectTitle(${i})" data-index="${i}">
              <div class="w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center text-[10px] font-bold mt-0.5 ${i === 0 ? 'bg-violet-500 text-white' : 'bg-slate-200 text-slate-500'}">
                ${i + 1}
              </div>
              <div class="flex-1 min-w-0">
                <span class="text-xs text-slate-800 leading-relaxed block">${title}</span>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-[10px] font-medium px-1.5 py-0.5 rounded border ${lenColor}">${len} chars · ${lenTip}</span>
                </div>
              </div>
            </div>`;
          }).join('');

          // Description - render with line breaks
          document.getElementById('pgAIDesc').innerHTML = (data.description || '').replace(/\n/g, '<br>');

          // Tags pills with category colors (matches AI tag strategy)
          const tagsEl = document.getElementById('pgAITagsContainer');
          const tags = data.tags || [];
          // Category boundaries based on AI prompt: broad(3), exact(5), long-tail(5), contextual(4), trending(3)
          const tagCategories = [
            { label: 'Broad', cls: 'bg-blue-100 text-blue-700 border-blue-200', count: 3 },
            { label: 'Exact', cls: 'bg-violet-100 text-violet-700 border-violet-200', count: 5 },
            { label: 'Long-tail', cls: 'bg-green-100 text-green-700 border-green-200', count: 5 },
            { label: 'Related', cls: 'bg-amber-100 text-amber-700 border-amber-200', count: 4 },
            { label: 'Trending', cls: 'bg-red-100 text-red-600 border-red-200', count: 3 }
          ];
          let catIdx = 0; let catCount = 0;
          const totalChars = tags.join('').length + tags.length;
          tagsEl.innerHTML = tags.map((tag, i) => {
            while (catIdx < tagCategories.length - 1 && catCount >= tagCategories[catIdx].count) { catIdx++; catCount = 0; }
            catCount++;
            const cat = tagCategories[Math.min(catIdx, tagCategories.length - 1)];
            return `<span class="group relative px-2 py-0.5 rounded-full text-[11px] font-medium border cursor-default ${cat.cls}" title="${cat.label} tag">#${tag}</span>`;
          }).join('');

          // Tag legend
          const legendEl = document.getElementById('pgAITagLegend');
          if (legendEl) {
            legendEl.innerHTML = tagCategories.map(c => 
              `<span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full ${c.cls.split(' ')[0]}"></span><span class="text-[10px] text-slate-400">${c.label}</span></span>`
            ).join('') + `<span class="text-[10px] text-slate-400 ml-auto">${totalChars}/500 chars</span>`;
          }
          document.getElementById('pgAITagCount').textContent = `(${tags.length})`;

          document.getElementById('pgAIResult').classList.remove('hidden');
          document.getElementById('pgAIResult').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }


        function pgSelectTitle(index) {
          pgSelectedTitleIndex = index;
          document.querySelectorAll('.pg-ai-title-item').forEach((el, i) => {
            const badge = el.querySelector('div');
            if (i === index) {
              el.className = 'pg-ai-title-item flex items-start gap-2 p-2.5 rounded-lg border-2 cursor-pointer transition-all border-violet-500 bg-violet-50';
              badge.className = 'w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center text-[10px] font-bold mt-0.5 bg-violet-500 text-white';
            } else {
              el.className = 'pg-ai-title-item flex items-start gap-2 p-2.5 rounded-lg border-2 cursor-pointer transition-all border-slate-200 bg-white hover:border-violet-300';
              badge.className = 'w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center text-[10px] font-bold mt-0.5 bg-slate-200 text-slate-500';
            }
          });
        }

        function pgApplyAI(type) {
          if (!pgAIData) return;
          const titles = pgAIData.titles || [];
          const selectedTitle = titles[pgSelectedTitleIndex] || titles[0] || '';

          if (type === 'title' || type === 'all') {
            const titleEl = document.getElementById('pgYtTitle');
            if (titleEl) { titleEl.value = selectedTitle; titleEl.dispatchEvent(new Event('input')); }
          }
          if (type === 'desc' || type === 'all') {
            const descEl = document.getElementById('pgYtDesc');
            if (descEl) { descEl.value = pgAIDesc; descEl.dispatchEvent(new Event('input')); }
          }
          if (type === 'tags' || type === 'all') {
            const tagsEl = document.getElementById('pgTags');
            if (tagsEl) { tagsEl.value = pgAITags.join(', '); tagsEl.dispatchEvent(new Event('input')); }
          }
          if (type === 'all') {
            // Flash feedback
            const btn = event.target.closest('button');
            const orig = btn.innerHTML;
            btn.innerHTML = '<i class="ti ti-check"></i> Berhasil Diterapkan!';
            btn.classList.add('bg-green-600');
            setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('bg-green-600'); }, 1500);
          }
        }

        // Legacy alias
        function applyAI(type) { pgApplyAI(type); }
      </script>

