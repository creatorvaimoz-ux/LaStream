  <script>
    (function () {
      const csrfToken = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
      let pgCurrentFilter = 'all';

      // Load videos into select
      async function pgLoadVideos() {
        try {
          const r = await fetch('/api/stream/content');
          const items = await r.json();
          const sel = document.getElementById('pgVideoSelect');
          if (!sel) return;
          sel.innerHTML = '<option value="">— Pilih video —</option>';
          items.forEach(i => {
            sel.innerHTML += `<option value="${i.id}">${i.name} (${i.duration || i.type})</option>`;
          });
        } catch (e) { }
      }

      // Load streams list
      async function pgLoadStreams() {
        try {
          const r = await fetch('/api/streams');
          const data = await r.json();
          let streams = data.streams || [];
          if (pgCurrentFilter !== 'all') streams = streams.filter(s => s.status === pgCurrentFilter);
          const el = document.getElementById('pgStreamsList');
          if (!el) return;
          if (streams.length === 0) {
            el.innerHTML = '<div class="text-center py-6 text-slate-500 text-xs"><i class="ti ti-broadcast-off text-2xl mb-1"></i><p>Tidak ada stream</p></div>';
            return;
          }
          el.innerHTML = streams.map(s => {
            const statusColors = { live: 'bg-red-500', scheduled: 'bg-yellow-500', offline: 'bg-slate-500' };
            const statusLabels = { live: 'Live', scheduled: 'Scheduled', offline: 'Offline' };
            return `<div class="flex items-center gap-3 p-2.5 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors">
          <div class="w-2 h-2 rounded-full ${statusColors[s.status] || 'bg-slate-500'} flex-shrink-0"></div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-white truncate">${s.title || 'Untitled'}</p>
            <p class="text-[10px] text-slate-500">${s.platform || 'Custom'} • ${statusLabels[s.status] || s.status}</p>
          </div>
          <div class="flex items-center gap-1 flex-shrink-0">
            ${s.status === 'live'
                ? `<button onclick="pgStopStream('${s.id}')" class="p-1 rounded hover:bg-red-500/20 text-red-400" title="Stop"><i class="ti ti-player-stop text-xs"></i></button>`
                : `<button onclick="pgStartStream('${s.id}')" class="p-1 rounded hover:bg-green-500/20 text-green-400" title="Start"><i class="ti ti-player-play text-xs"></i></button>`
              }
            <button onclick="pgDeleteStream('${s.id}')" class="p-1 rounded hover:bg-red-500/20 text-slate-500 hover:text-red-400" title="Delete"><i class="ti ti-trash text-xs"></i></button>
          </div>
        </div>`;
          }).join('');
        } catch (e) { }
      }

      window.pgFilterStreams = function (filter) {
        pgCurrentFilter = filter;
        document.querySelectorAll('.pg-tab-btn').forEach(b => {
          b.classList.remove('bg-primary', 'text-white');
          b.classList.add('text-slate-400');
          if (b.dataset.filter === filter) {
            b.classList.add('bg-primary', 'text-white');
            b.classList.remove('text-slate-400');
          }
        });
        pgLoadStreams();
      };
      window.pgStartStream = async function (id) {
        try { const r = await fetch(`/api/streams/${id}/start`, { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken } }); const d = await r.json(); if (d.success) pgLoadStreams(); else alert(d.error || 'Failed'); } catch (e) { alert('Error'); }
      };
      window.pgStopStream = async function (id) {
        if (!confirm('Stop stream ini?')) return;
        try { const r = await fetch(`/api/streams/${id}/stop`, { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken } }); const d = await r.json(); if (d.success) pgLoadStreams(); else alert(d.error || 'Failed'); } catch (e) { alert('Error'); }
      };
      window.pgDeleteStream = async function (id) {
        if (!confirm('Hapus stream ini?')) return;
        try { const r = await fetch(`/api/streams/${id}`, { method: 'DELETE', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken } }); const d = await r.json(); if (d.success) pgLoadStreams(); else alert(d.error || 'Failed'); } catch (e) { alert('Error'); }
      };

      pgLoadVideos();
      pgLoadStreams();
      setInterval(pgLoadStreams, 8000);
    })();
  </script>
