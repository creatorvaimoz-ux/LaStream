<% layout('layout') -%>
  
  <div class="page-header-row mb-6">
    <div>
      <h1 class="page-title">Pengaturan</h1>
      <p class="page-subtitle">Kelola akun dan preferensi Anda</p>
    </div>
  </div>
  
  <div class="mb-6" style="border-bottom:1px solid #e8edf3">
    <div class="flex flex-wrap -mb-px gap-1">
      <button class="settings-tab active" data-tab="profile">
        <i class="ti ti-user mr-1.5"></i>Profile
      </button>
      <button class="settings-tab" data-tab="security">
        <i class="ti ti-shield-lock mr-1.5"></i>Security
      </button>
      <button class="settings-tab" data-tab="integration">
        <i class="ti ti-plug mr-1.5"></i>Integration
      </button>
      <button class="settings-tab" data-tab="ai">
        <i class="ti ti-sparkles mr-1.5"></i>AI Keys
      </button>
      <button class="settings-tab" data-tab="logs">
        <i class="ti ti-file-text mr-1.5"></i>Logs
      </button>
      <button class="settings-tab" data-tab="about">
        <i class="ti ti-info-circle mr-1.5"></i>About
      </button>
    </div>
  </div>
  
  <div>
    
    <div id="profile-tab" class="settings-content">
      <div class="bg-white rounded-lg p-6">
        <h3 class="text-lg font-semibold mb-6">Profile Settings</h3>
        <form id="profile-form" class="space-y-6" action="/settings/profile" method="post"
          enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="activeTab" value="profile">
          
          <div class="space-y-4">
            <label class="block text-sm font-medium text-slate-600">Profile Photo</label>
            <div class="flex items-center space-x-6">
              <div class="relative">
                <div class="w-24 h-24 rounded-full bg-slate-100 overflow-hidden border-2 border-slate-200">
                  <img id="profile-preview" src="<%= user.avatar_path || '/images/default-avatar.jpg' %>"
                    class="w-full h-full object-cover" alt="Profile Photo"
                    onerror="this.src='/images/default-avatar.jpg'">
                </div>
                <div class="absolute bottom-0 right-0">
                  <label for="profile-upload"
                    class="flex items-center justify-center w-8 h-8 rounded-full bg-primary hover:bg-sky-700 cursor-pointer shadow-lg transition-colors">
                    <i class="ti ti-pencil text-slate-800 text-sm"></i>
                  </label>
                  <input id="profile-upload" name="avatar" type="file" accept="image/*" class="hidden">
                </div>
              </div>
              <div class="text-sm text-slate-500">
                <p>Upload a new photo</p>
                <p class="mt-1">Maximum file size: 2MB</p>
              </div>
            </div>
          </div>
          
          <div class="space-y-2">
            <label for="username" class="block text-sm font-medium text-slate-600">Username</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500">
                <i class="ti ti-user"></i>
              </span>
              <input type="text" id="username" name="username"
                class="bg-slate-50 text-slate-800 pl-10 pr-4 py-2 rounded-lg block w-full sm:max-w-md focus:outline-none focus:ring-1 focus:ring-primary"
                value="<%= user.username %>">
            </div>
          </div>
          
          <div class="pt-4">
            <button type="submit"
              class="px-4 py-2 bg-primary hover:bg-sky-700 text-white rounded-lg transition-colors">
              Save Profile Changes
            </button>
          </div>
        </form>
      </div>
    </div>
    
    <div id="security-tab" class="settings-content hidden">
      <div class="space-y-6">
        
        <div class="bg-white rounded-lg p-6">
          <h3 class="text-lg font-semibold mb-6">Change Password</h3>
          <form id="password-form" class="space-y-6" action="/settings/password" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="activeTab" value="security">
            
            <div class="space-y-2">
              <label for="current-password" class="block text-sm font-medium text-slate-600">Current Password</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500">
                  <i class="ti ti-lock"></i>
                </span>
                <input type="password" id="current-password" name="currentPassword"
                  class="bg-slate-50 text-slate-800 pl-10 pr-4 py-2 rounded-lg block w-full sm:max-w-md focus:outline-none focus:ring-1 focus:ring-primary"
                  placeholder="Enter your current password">
              </div>
            </div>
            
            <div class="space-y-2">
              <label for="new-password" class="block text-sm font-medium text-slate-600">New Password</label>
              <div class="relative sm:max-w-md">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500">
                  <i class="ti ti-lock"></i>
                </span>
                <input type="password" id="new-password" name="newPassword"
                  class="bg-slate-50 text-slate-800 pl-10 pr-10 py-2 rounded-lg block w-full focus:outline-none focus:ring-1 focus:ring-primary"
                  placeholder="Enter new password">
                <button type="button"
                  class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-500 hover:text-slate-900"
                  id="toggle-password">
                  <i class="ti ti-eye"></i>
                </button>
              </div>
              <div class="text-xs text-slate-500 mt-1">
                Password must be at least 8 characters and include uppercase, lowercase and a number
              </div>
            </div>
            
            <div class="space-y-2">
              <label for="confirm-password" class="block text-sm font-medium text-slate-600">Confirm New Password</label>
              <div class="relative sm:max-w-md">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500">
                  <i class="ti ti-lock"></i>
                </span>
                <input type="password" id="confirm-password" name="confirmPassword"
                  class="bg-slate-50 text-slate-800 pl-10 pr-4 py-2 rounded-lg block w-full focus:outline-none focus:ring-1 focus:ring-primary"
                  placeholder="Confirm new password">
              </div>
            </div>
            
            <div class="pt-4">
              <button type="submit"
                class="px-4 py-2 bg-primary hover:bg-sky-700 text-white rounded-lg transition-colors">
                Change Password
              </button>
            </div>
          </form>
        </div>

        <% if (user.user_role === 'admin') { %>
        <div class="bg-white rounded-lg p-6">
          <h3 class="text-lg font-semibold mb-6">Google reCAPTCHA Settings</h3>
          
          <div class="bg-blue-900/20 border border-blue-700/50 rounded-lg p-4 mb-6 sm:max-w-md">
            <div class="flex items-start gap-3">
              <i class="ti ti-info-circle text-primary text-xl flex-shrink-0 mt-0.5"></i>
              <div class="text-sm">
                <p class="text-primary font-medium mb-2">Enable <b>reCAPTCHA v2</b> to protect login page</p>
                <div class="flex flex-wrap gap-2">
                  <a href="https://www.google.com/recaptcha/admin" target="_blank" rel="noopener noreferrer" 
                    class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary hover:bg-blue-700 text-white rounded-lg transition-colors text-xs">
                    <i class="ti ti-external-link"></i>
                    Get reCAPTCHA Keys
                  </a>
                  <a href="https://youtu.be/-TUHupNHdpI" target="_blank" rel="noopener noreferrer" 
                    class="inline-flex items-center gap-2 px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors text-xs">
                    <i class="ti ti-brand-youtube-filled"></i>
                    Tutorial
                  </a>
                </div>
              </div>
            </div>
          </div>

          <form id="recaptcha-form" class="space-y-6" action="/settings/recaptcha" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="activeTab" value="security">

            <div class="space-y-2">
              <label for="recaptcha-site-key" class="block text-sm font-medium text-slate-600">
                <i class="ti ti-key mr-1"></i>Site Key
              </label>
              <div class="relative sm:max-w-md">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500">
                  <i class="ti ti-world"></i>
                </span>
                <input type="text" id="recaptcha-site-key" name="recaptchaSiteKey"
                  class="bg-slate-50 text-slate-800 pl-10 pr-4 py-2 rounded-lg block w-full focus:outline-none focus:ring-1 focus:ring-primary border border-slate-200"
                  placeholder="Enter your reCAPTCHA Site Key"
                  value="<%= typeof recaptchaSiteKey !== 'undefined' ? recaptchaSiteKey : '' %>">
              </div>
            </div>
            
            <div class="space-y-2">
              <label for="recaptcha-secret-key" class="block text-sm font-medium text-slate-600">
                <i class="ti ti-lock mr-1"></i>Secret Key
              </label>
              <div class="relative sm:max-w-md">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500">
                  <i class="ti ti-shield-lock"></i>
                </span>
                <input type="password" id="recaptcha-secret-key" name="recaptchaSecretKey"
                  class="bg-slate-50 text-slate-800 pl-10 pr-10 py-2 rounded-lg block w-full focus:outline-none focus:ring-1 focus:ring-primary border border-slate-200"
                  placeholder="Enter your reCAPTCHA Secret Key"
                  value="<%= typeof recaptchaSecretKey !== 'undefined' ? recaptchaSecretKey : '' %>">
                <button type="button"
                  class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-500 hover:text-slate-900"
                  id="toggle-recaptcha-secret">
                  <i class="ti ti-eye"></i>
                </button>
              </div>
              <% if (typeof hasRecaptchaKeys !== 'undefined' && hasRecaptchaKeys) { %>
              <p class="text-xs text-slate-400">Enter a new value to update</p>
              <% } %>
            </div>

            <div class="space-y-2">
              <label class="flex items-center justify-between sm:max-w-md cursor-pointer group <%= typeof hasRecaptchaKeys !== 'undefined' && hasRecaptchaKeys ? '' : 'opacity-50 pointer-events-none' %>">
                <div class="flex items-center gap-2">
                  <i class="ti ti-shield-check text-slate-500 group-hover:text-primary transition-colors"></i>
                  <span class="text-sm font-medium text-slate-600">Enable reCAPTCHA Protection</span>
                </div>
                <div class="relative">
                  <input type="checkbox" id="recaptcha-enabled" name="recaptchaEnabled" class="sr-only peer"
                    <%= typeof recaptchaEnabled !== 'undefined' && recaptchaEnabled ? 'checked' : '' %>
                    <%= typeof hasRecaptchaKeys !== 'undefined' && hasRecaptchaKeys ? '' : 'disabled' %>>
                  <div class="w-11 h-6 bg-slate-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary peer-disabled:opacity-50"></div>
                </div>
              </label>
              <p class="text-xs text-slate-400">
                <% if (typeof hasRecaptchaKeys !== 'undefined' && hasRecaptchaKeys) { %>
                <% } else { %>
                Save your reCAPTCHA keys first to enable this feature
                <% } %>
              </p>
            </div>

            <div class="flex items-center gap-3 pt-2">
              <button type="submit"
                class="px-4 py-2 bg-primary hover:bg-sky-700 text-white rounded-lg transition-colors">
                <i class="ti ti-device-floppy mr-2"></i>Save reCAPTCHA Keys
              </button>
              <% if (typeof hasRecaptchaKeys !== 'undefined' && hasRecaptchaKeys) { %>
              <button type="button" id="remove-recaptcha"
                class="px-4 py-2 bg-slate-100 hover:bg-red-600 text-white rounded-lg transition-colors">
                <i class="ti ti-trash mr-2"></i>Remove Keys
              </button>
              <% } %>
            </div>
          </form>
        </div>
        <% } %>

      </div>
    </div>


    <div id="integration-tab" class="settings-content hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- LEFT: Tambah Channel + Credentials Accordion -->
        <div class="space-y-4">

          <!-- Tambah Channel Baru -->
          <div class="bg-white rounded-lg p-5 border border-slate-200">
            <div class="flex items-center gap-2 mb-5">
              <i class="ti ti-plus text-primary text-base"></i>
              <h3 class="text-base font-semibold text-slate-800">Tambah Channel Baru (Login)</h3>
            </div>

            <!-- Step 1 -->
            <div class="flex justify-center mb-5">
              <button type="button" id="connect-youtube"
                class="px-5 py-2 bg-white border border-slate-300 hover:border-primary hover:text-primary text-slate-600 rounded-lg transition-all text-sm font-medium flex items-center gap-2 shadow-sm"
                <%= typeof hasYoutubeCredentials !== 'undefined' && hasYoutubeCredentials ? '' : 'disabled title="Isi Kredensial API dulu"' %>>
                <i class="ti ti-brand-google text-base"></i>
                1. Buka Login Google
              </button>
            </div>

            <!-- Step 2: Paste URL -->
            <div class="border border-dashed border-slate-300 rounded-lg p-4 mb-4">
              <label class="block text-sm font-medium text-slate-600 mb-2">
                2. Tempel URL Lengkap (Kode Akses)
              </label>
              <textarea id="youtube-auth-url"
                class="w-full bg-slate-50 text-slate-700 px-3 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary border border-slate-200 font-mono text-xs resize-y min-h-[90px]"
                placeholder="http://localhost/?state=ppVwnH...&code=4/0A..."></textarea>
            </div>

            <!-- Step 3: Save -->
            <button type="button" id="save-youtube-channel"
              class="w-full px-5 py-2.5 bg-primary hover:bg-sky-700 text-white rounded-lg transition-colors font-semibold text-sm">
              Simpan Akun Channel
            </button>
          </div>

          <!-- Ganti Kredensial API (Accordion) -->
          <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
            <button type="button" id="toggle-credentials-accordion"
              class="w-full flex items-center justify-between px-5 py-3.5 hover:bg-slate-50 transition-colors text-left"
              onclick="toggleCredentialsAccordion()">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center flex-shrink-0">
                  <i class="ti ti-alert-triangle text-amber-500 text-sm"></i>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-800">Ganti Kredensial API Google</div>
                  <div class="text-xs text-amber-600">Gunakan ini HANYA JIKA kuota harian API Anda habis (Quota Exceeded).</div>
                </div>
              </div>
              <i id="credentials-accordion-icon" class="ti ti-chevron-down text-slate-400 transition-transform duration-200"></i>
            </button>

            <div id="credentials-accordion-body" class="hidden border-t border-slate-100">
              <div class="p-5 space-y-4">
                <div>
                  <label class="block text-sm font-medium text-slate-600 mb-1.5">Client ID Baru</label>
                  <input type="text" id="youtube-client-id"
                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 px-3 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-sm"
                    placeholder="Contoh:  123456789-xxxxxx.apps.googleusercontent.com"
                    value="<%= typeof youtubeClientId !== 'undefined' ? youtubeClientId : '' %>">
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-600 mb-1.5">Client Secret Baru</label>
                  <input type="password" id="youtube-client-secret"
                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 px-3 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-sm"
                    placeholder="Contoh:  GOCSPX-xxxxxx_xxxxxxxxxx"
                    value="<%= typeof hasYoutubeCredentials !== 'undefined' && hasYoutubeCredentials ? '••••••••••••••••' : '' %>">
                </div>
                <button type="button" id="btn-save-credentials"
                  class="px-5 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-lg transition-colors text-sm font-semibold">
                  Timpa Kredensial API
                </button>
                <p class="text-xs text-slate-400 leading-relaxed border-t border-slate-100 pt-3">
                  <strong class="text-slate-500">Penting:</strong> Setelah mengganti Client ID, Anda wajib menghapus Channel Terhubung di atas dan melakukan Login ulang menggunakan URL yang baru agar sistem mengikat kuota API yang baru ke akun tersebut.
                </p>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Connected Channels -->
        <div class="bg-white rounded-lg border border-slate-200 p-5">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h4 class="text-base font-semibold text-slate-800">Channel Terhubung</h4>
              <p class="text-slate-400 text-xs mt-0.5">Kelola channel YouTube untuk streaming</p>
            </div>
            <% if (typeof youtubeChannels !== 'undefined' && youtubeChannels.length > 1) { %>
            <button type="button" id="disconnect-all-youtube"
              class="px-3 py-1.5 bg-slate-100 hover:bg-red-600 hover:text-white text-slate-500 rounded-lg transition-colors text-xs">
              <i class="ti ti-trash mr-1"></i>Putuskan Semua
            </button>
            <% } %>
          </div>

          <div id="youtube-channels-list" class="space-y-2">
            <% if (typeof youtubeChannels !== 'undefined' && youtubeChannels.length > 0) { %>
              <% youtubeChannels.forEach(function(channel) { %>
                <div class="bg-slate-50 rounded-lg p-3 border border-slate-200 channel-item" data-channel-id="<%= channel.id %>">
                  <div class="flex items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full overflow-hidden bg-slate-100 flex-shrink-0">
                        <% if (channel.channel_thumbnail) { %>
                          <img src="<%= channel.channel_thumbnail %>" alt="Channel" class="w-full h-full object-cover">
                        <% } else { %>
                          <div class="w-full h-full flex items-center justify-center bg-red-600">
                            <i class="ti ti-brand-youtube text-white"></i>
                          </div>
                        <% } %>
                      </div>
                      <div>
                        <div class="flex items-center gap-1.5">
                          <p class="text-sm font-medium text-slate-800"><%= channel.channel_name %></p>
                          <% if (channel.is_default) { %>
                            <span class="px-1.5 py-0.5 bg-sky-100 text-sky-600 text-[10px] rounded font-medium">Default</span>
                          <% } %>
                        </div>
                        <p class="text-[11px] text-slate-400"><%= Number(channel.subscriber_count || 0).toLocaleString() %> subscribers</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-1.5 flex-shrink-0">
                      <% if (!channel.is_default) { %>
                        <button type="button" onclick="setDefaultChannel('<%= channel.id %>')"
                          class="p-1.5 bg-slate-100 hover:bg-slate-200 text-slate-500 rounded-lg transition-colors text-xs" title="Set as default">
                          <i class="ti ti-star text-sm"></i>
                        </button>
                      <% } %>
                      <button type="button" onclick="disconnectChannel('<%= channel.id %>', '<%= channel.channel_name %>')"
                        class="p-1.5 bg-slate-100 hover:bg-red-600 hover:text-white text-slate-500 rounded-lg transition-colors text-xs" title="Disconnect">
                        <i class="ti ti-unlink text-sm"></i>
                      </button>
                    </div>
                  </div>
                </div>
              <% }); %>
            <% } else { %>
              <div class="text-center py-10">
                <div class="w-14 h-14 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-3">
                  <i class="ti ti-brand-youtube text-slate-300 text-2xl"></i>
                </div>
                <p class="text-sm font-medium text-slate-500">Belum ada channel terhubung</p>
                <p class="text-xs text-slate-400 mt-1">Login Google di sebelah kiri untuk menambahkan channel</p>
              </div>
            <% } %>
          </div>
        </div>

      </div>

      <script>
        function toggleCredentialsAccordion() {
          const body = document.getElementById('credentials-accordion-body');
          const icon = document.getElementById('credentials-accordion-icon');
          body.classList.toggle('hidden');
          icon.classList.toggle('rotate-180');
        }

        // Save credentials via the accordion form
        const btnSaveCreds = document.getElementById('btn-save-credentials');
        if (btnSaveCreds) {
          btnSaveCreds.addEventListener('click', async () => {
            const clientId = document.getElementById('youtube-client-id').value.trim();
            const clientSecret = document.getElementById('youtube-client-secret').value.trim();
            if (!clientId) { showToast('error', 'Masukkan Client ID'); return; }
            if (!clientSecret || clientSecret === '••••••••••••••••') { showToast('error', 'Masukkan Client Secret baru'); return; }
            try {
              const res = await fetch('/api/settings/youtube-credentials', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
                body: JSON.stringify({ clientId, clientSecret })
              });
              const data = await res.json();
              if (data.success) {
                showToast('success', 'Kredensial API berhasil disimpan!');
                const connectBtn = document.getElementById('connect-youtube');
                if (connectBtn) connectBtn.disabled = false;
                setTimeout(() => window.location.reload(), 1500);
              } else {
                showToast('error', data.error || 'Gagal menyimpan kredensial');
              }
            } catch(e) { showToast('error', 'Terjadi kesalahan'); }
          });
        }
      </script>

      <!-- Telegram Integration -->
      <div class="bg-white rounded-lg p-6 mt-6">

        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0">
              <i class="ti ti-brand-telegram text-2xl text-blue-500"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold">Telegram Notifikasi Bot</h3>
              <p class="text-slate-500 text-sm">Dapatkan notifikasi status streaming (dimulai, terhenti, error, dll)</p>
            </div>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="telegram-enable" class="sr-only peer" <%= typeof telegramSettings !== 'undefined' && telegramSettings.enabled ? 'checked' : '' %>>
            <div class="w-11 h-6 bg-slate-200 rounded-full peer peer-focus:ring-4 peer-focus:ring-blue-300 peer-checked:bg-blue-500 transition-colors"></div>
            <div class="absolute left-[2px] top-[2px] w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5 shadow-sm"></div>
          </label>
        </div>

        <div id="telegram-settings" class="<%= (typeof telegramSettings !== 'undefined' && telegramSettings.enabled) ? '' : 'hidden' %> border-t border-slate-100 pt-6 mt-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">Bot Token</label>
              <input type="text" id="telegram-token" placeholder="123456789:ABCdefGHIjklMNOpqrsTUVwxyz" value="<%= typeof telegramSettings !== 'undefined' ? telegramSettings.token : '' %>" class="w-full bg-slate-50 border border-slate-300 text-slate-800 px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
              <p class="text-xs text-slate-500 mt-1.5">Dapatkan token dari <a href="https://t.me/BotFather" target="_blank" class="text-blue-500 hover:underline">@BotFather</a></p>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">Chat ID</label>
              <div class="flex gap-2">
                <input type="text" id="telegram-chat-id" placeholder="-1001234567890" value="<%= typeof telegramSettings !== 'undefined' ? telegramSettings.chatId : '' %>" class="flex-1 bg-slate-50 border border-slate-300 text-slate-800 px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
                <button type="button" id="btn-test-telegram" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg text-sm font-medium transition-colors border border-slate-300 whitespace-nowrap flex items-center gap-2">
                  <i class="ti ti-send"></i> Test
                </button>
              </div>
              <p class="text-xs text-slate-500 mt-1.5">ID Grup, Channel, atau User untuk mengirim pesan</p>
            </div>
          </div>
          
          <div class="mt-6">
            <h4 class="text-sm font-medium text-slate-700 mb-3">Pilih Notifikasi</h4>
            <div class="flex flex-wrap gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="telegram-notify-start" <%= typeof telegramSettings === 'undefined' || telegramSettings.notifyStart ? 'checked' : '' %> class="rounded border-slate-300 text-blue-500 focus:ring-blue-500">
                <span class="text-sm text-slate-600">Stream Dimulai</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="telegram-notify-stop" <%= typeof telegramSettings === 'undefined' || telegramSettings.notifyStop ? 'checked' : '' %> class="rounded border-slate-300 text-blue-500 focus:ring-blue-500">
                <span class="text-sm text-slate-600">Stream Terhenti</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="telegram-notify-error" <%= typeof telegramSettings === 'undefined' || telegramSettings.notifyError ? 'checked' : '' %> class="rounded border-slate-300 text-blue-500 focus:ring-blue-500">
                <span class="text-sm text-slate-600">Error / Disconnect</span>
              </label>
            </div>
          </div>

          <div class="mt-6 flex justify-end">
            <button type="button" id="btn-save-telegram" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors font-medium text-sm flex items-center gap-2">
              <i class="ti ti-device-floppy"></i> Simpan Pengaturan Telegram
            </button>
          </div>
        </div>
      </div>
      <script>
        document.getElementById('telegram-enable').addEventListener('change', function() {
          const settings = document.getElementById('telegram-settings');
          if (this.checked) {
            settings.classList.remove('hidden');
          } else {
            settings.classList.add('hidden');
          }
        });

        // Test Telegram
        document.getElementById('btn-test-telegram').addEventListener('click', async function() {
          const token = document.getElementById('telegram-token').value;
          const chatId = document.getElementById('telegram-chat-id').value;
          
          if (!token || !chatId) {
            showToast('Silahkan isi Bot Token dan Chat ID terlebih dahulu', 'error');
            return;
          }
          
          const originalText = this.innerHTML;
          this.innerHTML = '<i class="ti ti-loader animate-spin"></i> Testing...';
          this.disabled = true;
          
          try {
            const response = await fetch('/api/settings/telegram/test', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ token, chatId })
            });
            const data = await response.json();
            
            if (data.success) {
              showToast('Test pesan berhasil dikirim ke Telegram!', 'success');
            } else {
              showToast('Error: ' + data.error, 'error');
            }
          } catch (error) {
            showToast('Gagal terhubung ke server', 'error');
          } finally {
            this.innerHTML = originalText;
            this.disabled = false;
          }
        });

        // Save Telegram Settings
        document.getElementById('btn-save-telegram').addEventListener('click', async function() {
          const enabled = document.getElementById('telegram-enable').checked;
          const token = document.getElementById('telegram-token').value;
          const chatId = document.getElementById('telegram-chat-id').value;
          const notifyStart = document.getElementById('telegram-notify-start').checked;
          const notifyStop = document.getElementById('telegram-notify-stop').checked;
          const notifyError = document.getElementById('telegram-notify-error').checked;
          
          const originalText = this.innerHTML;
          this.innerHTML = '<i class="ti ti-loader animate-spin"></i> Menyimpan...';
          this.disabled = true;
          
          try {
            const response = await fetch('/api/settings/telegram', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                enabled, token, chatId, notifyStart, notifyStop, notifyError
              })
            });
            const data = await response.json();
            
            if (data.success) {
              showToast('Pengaturan Telegram berhasil disimpan', 'success');
            } else {
              showToast('Error: ' + data.error, 'error');
            }
          } catch (error) {
            showToast('Gagal menyimpan pengaturan', 'error');
          } finally {
            this.innerHTML = originalText;
            this.disabled = false;
          }
        });
      </script>
    </div>

