<script>
function filterRotTab(tab, btn) {
  // Update active tab button
  document.querySelectorAll('.rot-tab').forEach(b => {
    b.className = 'rot-tab px-3 py-1 text-xs font-medium rounded-full text-slate-500 hover:bg-slate-100 transition-colors';
  });
  btn.className = 'rot-tab px-3 py-1 text-xs font-medium rounded-full bg-primary text-white';
  // Filter rows
  document.querySelectorAll('.rot-item').forEach(row => {
    if (tab === 'all') {
      row.style.display = '';
    } else {
      row.style.display = row.dataset.tab === tab ? '' : 'none';
    }
  });
}
