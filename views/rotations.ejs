<script>
async function generateRotationItemAI(idx) {
  const itemEl = document.querySelector(`.rotation-item[data-index="${idx}"]`);
  if (!itemEl) return;
  
  const prompt = itemEl.querySelector('.rotation-ai-prompt').value;
  const lang = itemEl.querySelector('.rotation-ai-lang').value;
  const style = itemEl.querySelector('.rotation-ai-style').value;
  const btn = itemEl.querySelector('button[onclick^="generateRotationItemAI"]');
  const originalBtnText = btn.innerHTML;
  
  if (!prompt.trim()) {
    showToast('error', 'Silakan masukkan topik / konteks untuk AI.');
    return;
  }
  
  btn.innerHTML = '<i class="ti ti-loader animate-spin"></i> Generating...';
  btn.disabled = true;
  btn.classList.add('opacity-70', 'cursor-not-allowed');
  
  try {
    const response = await fetch('/api/ai/generate', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken
      },
      body: JSON.stringify({
        prompt: prompt,
        targetLanguage: lang,
        style: style
      })
    });
    
    const data = await response.json();
    
    if (data.success) {
      itemEl.querySelector(`input[name="items[${idx}][title]"]`).value = data.title;
      itemEl.querySelector(`textarea[name="items[${idx}][description]"]`).value = data.description;
      
      const tagsStr = Array.isArray(data.tags) ? data.tags.join(', ') : data.tags;
      const tagsContainer = itemEl.querySelector('.tags-container');
      if (tagsContainer && tagsContainer._addTags) {
        tagsContainer._tags = [];
        tagsContainer._renderTags();
        tagsContainer._addTags(tagsStr);
      } else {
        itemEl.querySelector('.tags-hidden').value = tagsStr;
      }
      
      showToast('success', 'AI Metadata berhasil digenerate!');
      
      const aiPanel = itemEl.querySelector('.rotation-ai-prompt').closest('div.hidden');
      if (aiPanel) aiPanel.classList.add('hidden');
      
    } else {
      showToast('error', data.error || 'Gagal generate konten AI.');
    }
  } catch (error) {
    console.error('AI Error:', error);
    showToast('error', 'Terjadi kesalahan saat memanggil AI.');
  } finally {
    btn.innerHTML = originalBtnText;
    btn.disabled = false;
    btn.classList.remove('opacity-70', 'cursor-not-allowed');
  }
}
</script>
