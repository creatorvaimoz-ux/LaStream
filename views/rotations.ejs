    toastIcon.className = 'ti ti-alert-triangle text-yellow-400 text-xl mr-2 font-loaded';
    toast.classList.add('border-l-4', 'border-yellow-400');
    toast.classList.remove('border-l-4', 'border-green-400', 'border-red-400');
