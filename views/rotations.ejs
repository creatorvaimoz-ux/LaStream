<% layout('layout') -%>

<div class="page-header-row mb-6">
  <div>
    <h1 class="page-title">Tugas Live</h1>
    <p class="page-subtitle">Auto-rotate YouTube streams dengan metadata berbeda</p>
  </div>
  <% if (youtubeConnected) { %>
  <% } %>
</div>

<% if (!youtubeConnected) { %>
<div class="rounded-xl p-6 mb-6" style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.2)">
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(245,158,11,0.15)">
      <i class="ti ti-brand-youtube text-amber-500 text-2xl"></i>
    </div>
    <div>
      <h3 class="text-base font-semibold text-amber-800">YouTube Connection Required</h3>
      <p class="text-amber-700 text-sm mt-1">Untuk menggunakan Stream Rotations, hubungkan akun YouTube Anda terlebih dahulu.</p>
      <a href="/settings?activeTab=integration" class="inline-flex items-center gap-2 mt-3 px-4 py-2 rounded-lg text-sm font-semibold text-white transition-colors" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
        <i class="ti ti-plug"></i>
        <span>Connect YouTube</span>
      </a>
    </div>
  </div>
</div>
<% } else { %>

<!-- MAIN FORM (Always visible) -->
<form id="rotationForm" class="space-y-6">
  <input type="hidden" id="rotationId" name="rotationId" value="">
  
  <div class="flex flex-col lg:flex-row gap-3 sm:gap-5 w-full items-start" id="LiveTaskFormGrid">
    
    <!-- ========== LEFT COLUMN ========== -->
    <div class="w-full lg:w-[60%] space-y-3 sm:space-y-5 flex-shrink-0">
      <!-- StreamGeneralSettingsCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-4 border-b border-slate-200/60 bg-slate-50/50">
            <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
               <i class="ti ti-settings text-primary"></i> Pengaturan Global (Semua Video)
            </h3>
         </div>
         <div class="p-5 space-y-4">
            <div>
              <label class="text-sm font-medium text-slate-800 block mb-2">Nama Tugas Live</label>
              <input type="text" id="rotationName" name="rotationName" class="w-full px-4 py-2.5 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Contoh: Lo-fi Jazz Stream" required>
            </div>
            
            <div>
              <label class="text-sm font-medium text-slate-800 block mb-2">Pilih Video <span class="text-xs text-slate-500 font-normal">(Bisa pilih > 1 untuk acak, gunakan Ctrl/Cmd)</span></label>
              <select id="globalVideos" name="globalVideos" multiple class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary h-32 text-sm">
                <!-- Will be populated by JS -->
              </select>
            </div>
            
            <div>
              <label class="text-sm font-medium text-slate-800 block mb-2">Jenis Jalur Keluaran</label>
              <select id="outputMode" class="w-full px-4 py-2.5 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary">
                <option value="api">YouTube API v3 [Auto]</option>
                <option value="rtmp">RTMP Manual</option>
              </select>
            </div>
            
            <div class="flex items-start gap-2">
              <input type="checkbox" id="loopVideos" checked class="mt-1 w-4 h-4 text-primary border-slate-300 rounded focus:ring-primary">
              <label for="loopVideos" class="text-sm text-slate-700">Video di-loop terus menerus selama jadwal aktif</label>
            </div>
            
            <div class="p-3 bg-blue-50 text-blue-800 rounded-lg text-xs flex gap-2 items-start">
              <i class="ti ti-info-circle text-lg mt-0.5"></i>
              <p>Mode API: Isi cukup detail dibawah dan YouTube Studio akan mengatur broadcast key secara otomatis. Pastikan terhubung ke YouTube di menu Settings -> Integrasi & akun.</p>
            </div>
         </div>
      </div>
      
      <!-- YouTubeMetadataCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-4 border-b border-slate-200/60 bg-slate-50/50">
            <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
               <i class="ti ti-brand-youtube text-red-500"></i> Metadata YouTube Studio
            </h3>
         </div>
         <div class="p-5 space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="text-sm font-medium text-slate-800 block mb-2">Pilih Channel</label>
                <div class="relative" id="rotationChannelSelector">
                  <button type="button" onclick="toggleRotationChannelDropdown()" class="w-full flex items-center gap-3 px-3 py-2 bg-slate-100 border border-slate-300 rounded-lg hover:border-slate-300 focus:border-primary focus:ring-1 focus:ring-primary transition-colors text-left">
                    <img id="rotationChannelThumb" src="<%= typeof youtubeChannels !== 'undefined' && youtubeChannels.length > 0 ? (youtubeChannels.find(c => c.is_default) || youtubeChannels[0]).channel_thumbnail : '' %>" alt="" class="w-6 h-6 rounded-full object-cover flex-shrink-0" onerror="this.src='/images/default-avatar.jpg'">
                    <span id="rotationChannelName" class="flex-1 text-sm text-slate-800 truncate"><%= typeof youtubeChannels !== 'undefined' && youtubeChannels.length > 0 ? (youtubeChannels.find(c => c.is_default) || youtubeChannels[0]).channel_name : 'Select Channel' %></span>
                    <i class="ti ti-chevron-down text-slate-500 flex-shrink-0"></i>
                  </button>
                  <div id="rotationChannelDropdown" class="hidden absolute z-30 mt-1 w-full bg-slate-100 border border-slate-300 rounded-lg shadow-lg overflow-hidden">
                    <% if (typeof youtubeChannels !== 'undefined' && youtubeChannels.length > 0) { %>
                      <% youtubeChannels.forEach(function(channel) { %>
                      <button type="button" onclick="selectRotationChannel('<%= channel.id %>', '<%= channel.channel_name %>', '<%= channel.channel_thumbnail %>')" class="w-full flex items-center gap-3 px-3 py-2.5 hover:bg-slate-200 text-left rotation-channel-option" data-channel-id="<%= channel.id %>">
                        <img src="<%= channel.channel_thumbnail %>" alt="" class="w-6 h-6 rounded-full object-cover flex-shrink-0" onerror="this.src='/images/default-channel.png'">
                        <span class="text-sm text-slate-800 truncate"><%= channel.channel_name %></span>
                      </button>
                      <% }); %>
                    <% } %>
                  </div>
                  <input type="hidden" id="rotationChannelId" name="rotationChannelId" value="<%= typeof youtubeChannels !== 'undefined' && youtubeChannels.length > 0 ? (youtubeChannels.find(c => c.is_default) || youtubeChannels[0]).id : '' %>">
                </div>
              </div>
              <div>
                <label class="text-sm font-medium text-slate-800 block mb-2">Ketersediaan</label>
                <select id="globalPrivacy" name="globalPrivacy" class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary">
                  <option value="public">Public</option>
                  <option value="unlisted" selected>Unlisted</option>
                  <option value="private">Private</option>
                </select>
              </div>
            </div>
            
            <div>
              <label class="text-sm font-medium text-slate-800 block mb-2">Judul Video untuk YouTube <span class="text-xs text-slate-500 font-normal">(Tulis satu baris satu judul untuk diacak)</span></label>
              <textarea id="globalTitles" class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary h-24 text-sm" placeholder="Contoh:&#10;Morning Jazz Relaxing Music 24/7&#10;Cafe Jazz Piano - Chill Background Music"></textarea>
              <p class="text-[10px] text-slate-500 mt-1">Jika lebih dari 1 baris, judul akan dipilih secara acak saat live dimulai.</p>
            </div>
            
            <div>
              <label class="text-sm font-medium text-slate-800 block mb-2">Deskripsi</label>
              <textarea id="globalDescription" class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary h-24 text-sm" placeholder="Deskripsi untuk video YouTube..."></textarea>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="text-sm font-medium text-slate-800 block mb-2">Kategori</label>
                <select id="globalCategory" name="globalCategory" class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary">
                  <option value="22">People & Blogs</option>
                  <option value="20">Gaming</option>
                  <option value="24">Entertainment</option>
                  <option value="10">Music</option>
                  <option value="28">Science & Technology</option>
                  <option value="17">Sports</option>
                  <option value="27">Education</option>
                </select>
              </div>
              <div>
                <label class="text-sm font-medium text-slate-800 block mb-2">Tags</label>
                <input type="text" id="globalTags" class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary" placeholder="tag1, tag2, tag3...">
              </div>
            </div>
            
            <div class="flex items-start gap-2 pt-2 border-t border-slate-100">
              <input type="checkbox" id="globalClosedCaptions" class="mt-1 w-4 h-4 text-primary border-slate-300 rounded focus:ring-primary">
              <label for="globalClosedCaptions" class="text-sm text-slate-700">
                <span class="font-medium block">Auto-Generated Subtitles</span>
                <span class="text-xs text-slate-500">Aktifkan Closed Captions (Subtitle) otomatis dari YouTube</span>
              </label>
            </div>
            <p class="text-xs text-slate-500 italic mt-2">Default: metadata diambil dari nama file & pengaturan akun YouTube anda.</p>
         </div>
      </div>
      
      <!-- VodAfterLiveCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-4 border-b border-slate-200/60 bg-slate-50/50 flex justify-between items-center cursor-pointer" onclick="document.getElementById('vodBody').classList.toggle('hidden')">
            <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
               <i class="ti ti-video text-indigo-500"></i> VOD After Live <span class="bg-indigo-100 text-indigo-600 text-[10px] px-2 py-0.5 rounded-full ml-2">Setelah stream selesai</span>
            </h3>
            <i class="ti ti-chevron-down text-slate-400"></i>
         </div>
         <div class="p-5 space-y-4" id="vodBody">
            <p class="text-sm text-slate-600">Atur apa yang terjadi pada rekaman stream setelah live selesai.</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
               <div>
                  <label class="text-sm font-medium text-slate-800 block mb-2">Visibilitas VOD</label>
                  <select class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary">
                     <option>🔗 Unlisted — Hanya yang punya link</option>
                  </select>
               </div>
               <div>
                  <label class="text-sm font-medium text-slate-800 block mb-2">Tunda Publish VOD</label>
                  <select class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary">
                     <option>Langsung (segera setelah live)</option>
                  </select>
               </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
               <div class="flex items-start gap-2 p-3 border border-slate-200 rounded-lg bg-slate-50">
                  <input type="checkbox" checked class="mt-1 w-4 h-4 text-primary border-slate-300 rounded focus:ring-primary">
                  <label class="text-sm text-slate-700">
                    <span class="font-medium block">Auto Chapter</span>
                    <span class="text-xs text-slate-500">Bagi VOD ke chapter otomatis</span>
                  </label>
               </div>
               <div class="flex items-start gap-2 p-3 border border-slate-200 rounded-lg bg-slate-50">
                  <input type="checkbox" class="mt-1 w-4 h-4 text-primary border-slate-300 rounded focus:ring-primary">
                  <label class="text-sm text-slate-700">
                    <span class="font-medium block">Auto Highlight Clip</span>
                    <span class="text-xs text-slate-500">Buat clip highlight otomatis</span>
                  </label>
               </div>
            </div>
         </div>
      </div>
    </div>
    
    <!-- ========== RIGHT COLUMN ========== -->
    <div class="w-full lg:w-[40%] space-y-3 sm:space-y-5 flex-shrink-0">
      <!-- ThumbnailSettingsCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-3 border-b border-slate-200/60 bg-yellow-50/50">
            <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
               <i class="ti ti-photo text-yellow-500"></i> Program Thumbnail
            </h3>
         </div>
         <div class="p-4">
            <div class="thumbnail-upload-area relative border-2 border-dashed border-slate-300 rounded-lg hover:border-primary bg-slate-50 transition-colors cursor-pointer group h-32 flex flex-col items-center justify-center overflow-hidden" onclick="document.getElementById('globalThumbnail').click()">
              <input type="file" id="globalThumbnail" class="hidden" accept="image/jpeg,image/png,image/webp">
              <div class="thumbnail-placeholder text-center px-4 z-10">
                <div class="w-10 h-10 mx-auto bg-white rounded-full shadow-sm flex items-center justify-center mb-2 group-hover:scale-110 transition-transform">
                  <i class="ti ti-photo-plus text-xl text-slate-400 group-hover:text-primary"></i>
                </div>
                <p class="text-xs text-slate-500 font-medium">Upload Thumbnail</p>
                <p class="text-[10px] text-slate-400 mt-0.5">Disarankan 1280x720 (Max 2MB)</p>
              </div>
              <div class="thumbnail-preview hidden absolute inset-0 z-20 bg-black">
                <img id="globalThumbnailPreview" src="" class="w-full h-full object-contain">
                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 flex flex-col items-center justify-center transition-opacity">
                  <i class="ti ti-edit text-white text-2xl mb-1"></i>
                  <span class="text-white text-xs font-medium">Ubah Gambar</span>
                </div>
              </div>
            </div>
         </div>
      </div>
      
      <!-- SchedulePublishCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-3 border-b border-slate-200/60 bg-slate-50/50">
            <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
               <i class="ti ti-calendar-time text-slate-500"></i> Jadwal Penayangan Live Streaming
            </h3>
         </div>
         <div class="p-4 space-y-4">
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-[11px] font-medium text-slate-600 block mb-1">Jadwal Mulai</label>
                <input type="date" id="rotationStartDate" class="w-full px-3 py-1.5 text-sm bg-slate-50 border border-slate-300 rounded focus:border-primary focus:ring-1 focus:ring-primary">
              </div>
              <div>
                <label class="text-[11px] font-medium text-slate-600 block mb-1">Jadwal Selesai</label>
                <input type="date" id="rotationEndDate" class="w-full px-3 py-1.5 text-sm bg-slate-50 border border-slate-300 rounded focus:border-primary focus:ring-1 focus:ring-primary">
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-[11px] font-medium text-slate-600 block mb-1">Repeat Mode</label>
                <select id="repeatMode" name="repeatMode" class="w-full px-3 py-1.5 text-sm bg-slate-50 border border-slate-300 rounded focus:border-primary focus:ring-1 focus:ring-primary">
                  <option value="none">Tidak Diulang</option>
                  <option value="daily" selected>Setiap Hari</option>
                  <option value="weekly">Setiap Minggu</option>
                  <option value="monthly">Setiap Bulan</option>
                </select>
              </div>
              <div>
                <label class="text-[11px] font-medium text-slate-600 block mb-1">Pengulangan Waktu / 24 Jam</label>
                <div class="flex items-center gap-1">
                  <input type="time" id="rotationStartTime" name="rotationStartTime" class="w-full px-2 py-1.5 text-sm bg-slate-50 border border-slate-300 rounded focus:border-primary focus:ring-1 focus:ring-primary" required>
                  <span class="text-slate-400">-</span>
                  <input type="time" id="rotationEndTime" name="rotationEndTime" class="w-full px-2 py-1.5 text-sm bg-slate-50 border border-slate-300 rounded focus:border-primary focus:ring-1 focus:ring-primary" required>
                </div>
              </div>
            </div>
            
            <div class="flex items-start gap-2 pt-2">
              <input type="checkbox" id="autoPublish" class="mt-0.5 w-3.5 h-3.5 text-primary border-slate-300 rounded focus:ring-primary">
              <label for="autoPublish" class="text-[11px] text-slate-600">Auto Publish saat jadwal mulai tercapai</label>
            </div>
            
            <div class="p-3 bg-slate-50 border border-slate-200 rounded-lg flex items-center justify-between">
               <div>
                 <span class="text-sm font-medium text-slate-700 block">Acak +/- 15 mnt (Anti-Spam)</span>
                 <span class="text-[10px] text-slate-500">Mengacak waktu mulai/selesai agar tidak terdeteksi spam oleh YouTube</span>
               </div>
               <label class="relative inline-flex items-center cursor-pointer">
                 <input type="checkbox" id="randomizeTime" class="sr-only peer">
                 <div class="w-9 h-5 bg-slate-200 rounded-full peer peer-checked:bg-primary"></div>
                 <div class="absolute left-[2px] top-[2px] w-4 h-4 bg-white rounded-full transition-all peer-checked:translate-x-4 shadow"></div>
               </label>
            </div>
         </div>
      </div>
      
      <!-- ContentAICard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-3 border-b border-slate-200/60 bg-violet-50/50 flex justify-between items-center cursor-pointer" onclick="document.getElementById('aiBody').classList.toggle('hidden')">
            <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
               <i class="ti ti-sparkles text-violet-500"></i> Content AI <span class="bg-white border border-slate-200 text-slate-500 text-[10px] px-2 py-0.5 rounded-full ml-2">VidIQ-style</span>
            </h3>
            <i class="ti ti-chevron-down text-slate-400"></i>
         </div>
         <div class="p-4 space-y-4" id="aiBody">
            <div class="flex bg-slate-100 p-1 rounded-lg">
               <button type="button" class="flex-1 py-1.5 text-xs font-medium bg-white shadow-sm rounded text-slate-800 flex items-center justify-center gap-1"><i class="ti ti-sparkles text-violet-500"></i> Gemini</button>
               <button type="button" class="flex-1 py-1.5 text-xs font-medium text-slate-500 hover:text-slate-800 flex items-center justify-center gap-1"><i class="ti ti-message-chatbot"></i> ChatGPT</button>
            </div>
            
            <div>
              <label class="text-[11px] font-medium text-slate-600 block mb-1">Topik / Konteks Stream <span class="text-red-500">*</span></label>
              <input type="text" id="aiTopic" class="w-full px-3 py-2 text-sm bg-slate-50 border border-slate-300 rounded focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Contoh: Mountain River Waterfall, Live musik Jazz malam...">
            </div>
            
            <button type="button" class="text-xs text-primary hover:text-blue-700 font-medium flex items-center gap-1"><i class="ti ti-plus"></i> Tambah Judul Referensi Kompetitor</button>
            
            <div class="grid grid-cols-3 gap-2">
               <div>
                  <label class="text-[10px] font-medium text-slate-600 block mb-1">Bahasa</label>
                  <select class="w-full px-2 py-1.5 text-[11px] bg-slate-50 border border-slate-300 rounded"><option>🌐 Auto Detect</option></select>
               </div>
               <div>
                  <label class="text-[10px] font-medium text-slate-600 block mb-1">Gaya</label>
                  <select class="w-full px-2 py-1.5 text-[11px] bg-slate-50 border border-slate-300 rounded"><option>😊 Santai</option></select>
               </div>
               <div>
                  <label class="text-[10px] font-medium text-slate-600 block mb-1">Jumlah Judul</label>
                  <select class="w-full px-2 py-1.5 text-[11px] bg-slate-50 border border-slate-300 rounded"><option>3 Variasi</option></select>
               </div>
            </div>
            
            <button type="button" onclick="generateGlobalAI()" class="w-full py-2 bg-slate-800 hover:bg-slate-900 text-white text-xs font-medium rounded-lg flex items-center justify-center gap-2 transition-colors">
               <i class="ti ti-sparkles"></i> Generate dengan AI
            </button>
         </div>
      </div>
      
      <!-- MonetizationCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-3 bg-green-50/50 flex justify-between items-center cursor-pointer" onclick="document.getElementById('monetizationBody').classList.toggle('hidden')">
            <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
               <span class="w-5 h-5 rounded-full bg-green-100 flex items-center justify-center text-green-600"><i class="ti ti-currency-dollar text-xs"></i></span> Monetisasi Stream
            </h3>
            <i class="ti ti-chevron-down text-slate-400"></i>
         </div>
         <div class="p-4 border-t border-slate-100 hidden" id="monetizationBody">
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-slate-700 block">YouTube Partner Monetization</span>
                <span class="text-[10px] text-slate-500">Aktifkan iklan pada stream ini</span>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="globalMonetization" name="globalMonetization" class="sr-only peer">
                <div class="w-9 h-5 bg-slate-200 rounded-full peer peer-checked:bg-green-500"></div>
                <div class="absolute left-[2px] top-[2px] w-4 h-4 bg-white rounded-full transition-all peer-checked:translate-x-4 shadow"></div>
              </label>
            </div>
         </div>
      </div>
      
      <!-- OverlayWatermarkCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-3 flex justify-between items-center cursor-pointer" onclick="document.getElementById('overlayBody').classList.toggle('hidden')">
            <h3 class="text-xs font-semibold text-slate-700 flex items-center gap-2">
               <i class="ti ti-layers-intersect text-pink-500"></i> Dynamic Overlays & Watermark (Opsional)
            </h3>
            <i class="ti ti-chevron-down text-slate-400"></i>
         </div>
         <div class="p-4 border-t border-slate-100 hidden" id="overlayBody">
            <p class="text-[11px] text-slate-500">Fitur overlay dinamis akan segera hadir.</p>
         </div>
      </div>
      
      <!-- TranscoderOutputCard -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
         <div class="px-5 py-3 flex justify-between items-center cursor-pointer" onclick="document.getElementById('transcoderBody').classList.toggle('hidden')">
            <h3 class="text-xs font-semibold text-slate-700 flex items-center gap-2">
               <i class="ti ti-cpu text-blue-500"></i> Transkoder & Output
            </h3>
            <i class="ti ti-chevron-down text-slate-400"></i>
         </div>
