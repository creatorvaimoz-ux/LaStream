// ── YOUTUBE PLAYLIST FUNCTIONS ─────────────────────────────────────────────
async function loadYtPlaylists(idx) {
  const itemEl = document.querySelector(`.rotation-item[data-index="${idx}"]`);
  if (!itemEl) return;
  const select = itemEl.querySelector('.yt-playlist-select');
  if (!select) return;
  const channelId = document.getElementById('rotationChannelId')?.value || '';
  select.innerHTML = '<option value="">Memuat...</option>';
  try {
    const res = await fetch(`/api/youtube/playlists?channelId=${encodeURIComponent(channelId)}`);
    const data = await res.json();
    if (!data.success || !data.playlists.length) {
      select.innerHTML = '<option value="">-- Belum ada playlist --</option>';
      return;
    }
    select.innerHTML = '<option value="">-- Tidak dimasukkan playlist --</option>' +
      data.playlists.map(p => `<option value="${p.id}">${p.title} (${p.itemCount} video)</option>`).join('');
  } catch(e) {
    select.innerHTML = '<option value="">Gagal memuat playlist</option>';
  }
}

async function createYtPlaylist(idx) {
  const itemEl = document.querySelector(`.rotation-item[data-index="${idx}"]`);
  if (!itemEl) return;
  const titleInput = itemEl.querySelector('.yt-new-playlist-title');
  const privacySelect = itemEl.querySelector('.yt-new-playlist-privacy');
  const title = titleInput?.value?.trim();
  if (!title) { showToast('warning', 'Masukkan nama playlist terlebih dahulu.'); return; }
  const channelId = document.getElementById('rotationChannelId')?.value || '';
  try {
    const res = await fetch('/api/youtube/playlists', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ title, privacy: privacySelect?.value || 'public', channelId })
    });
    const data = await res.json();
    if (data.success) {
      showToast('success', `Playlist "${data.playlist.title}" berhasil dibuat!`);
      if (titleInput) titleInput.value = '';
      await loadYtPlaylists(idx);
      const select = itemEl.querySelector('.yt-playlist-select');
      if (select && data.playlist.id) select.value = data.playlist.id;
    } else {
      showToast('error', data.error || 'Gagal membuat playlist.');
    }
  } catch(e) {
    showToast('error', 'Gagal membuat playlist: ' + e.message);
  }
}

// ── AI CHECKLIST FUNCTIONS ─────────────────────────────────────────────────
function toggleAiChecklist(idx) {
  const container = document.querySelector(`.rotation-item[data-index="${idx}"]`);
  if (!container) return;
  const section = container.querySelector('.ai-checklist-section');
  const chevron = container.querySelector('.ai-checklist-chevron');
  if (!section) return;
  const isHidden = section.classList.contains('hidden');
  section.classList.toggle('hidden');
  if (chevron) chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
  if (isHidden) {
    // Bind checkbox change events
    section.querySelectorAll('.ai-check-item').forEach(cb => {
      cb.addEventListener('change', () => updateAiChecklistProgress(idx));
    });
  }
}

function updateAiChecklistProgress(idx) {
  const container = document.querySelector(`.rotation-item[data-index="${idx}"]`);
  if (!container) return;
  const items = container.querySelectorAll('.ai-check-item');
  const checked = container.querySelectorAll('.ai-check-item:checked').length;
  const total = items.length;
  const progress = container.querySelector('.ai-checklist-progress');
  const bar = container.querySelector('.ai-checklist-bar');
  const badge = container.querySelector('.ai-check-badge');
  if (progress) progress.textContent = `${checked}/${total} item diverifikasi`;
  if (bar) bar.style.width = `${Math.round((checked / total) * 100)}%`;
  if (badge) {
    if (checked > 0) {
      badge.classList.remove('hidden');
      badge.textContent = `${checked}/${total}`;
      badge.className = `ai-check-badge text-[10px] rounded-full px-1.5 py-0.5 font-medium ${checked === total ? 'bg-green-500 text-white' : 'bg-sky-500 text-white'}`;
    } else {
      badge.classList.add('hidden');
    }
  }
}

