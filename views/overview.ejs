<% layout('layout') %>

<div class="space-y-3">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-lg font-bold text-slate-800">Dashboard</h1>
      <p class="text-slate-400 text-xs mt-0.5">Selamat datang, <%= user.username %>!</p>
    </div>
    <a href="/rotations" class="inline-flex items-center gap-1.5 bg-primary hover:bg-sky-700 text-white px-3 py-1.5 rounded-lg font-medium transition-colors text-xs">
      <i class="ti ti-broadcast"></i>
      <span>Stream Baru</span>
    </a>
  </div>

  <!-- Stats + System Monitor dalam satu baris -->
  <div class="grid grid-cols-4 gap-2.5">
    <!-- Total Streams -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-broadcast text-primary text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none"><%= totalStreams %></div>
        <div class="text-[11px] text-slate-400 mt-0.5">Stream</div>
      </div>
      <% if (liveStreams > 0) { %>
      <span class="ml-auto flex items-center gap-1 text-[10px] font-medium text-red-500">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>LIVE
      </span>
      <% } else { %>
      <span class="ml-auto text-[10px] font-medium text-slate-300">OFFLINE</span>
      <% } %>
    </div>

    <!-- Live Now -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-live-photo text-red-400 text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none"><%= liveStreams %></div>
        <div class="text-[11px] text-slate-400 mt-0.5">Sedang Live</div>
      </div>
    </div>

    <!-- Total Videos -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-video text-violet-400 text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none"><%= totalVideos %></div>
        <div class="text-[11px] text-slate-400 mt-0.5">Video</div>
      </div>
    </div>

    <!-- Rotations -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-rotate text-emerald-400 text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none"><%= totalRotations %></div>
        <div class="text-[11px] text-slate-400 mt-0.5">Rotasi</div>
      </div>
      <% if (activeRotations > 0) { %>
      <span class="ml-auto text-[10px] font-medium text-emerald-500"><%= activeRotations %> aktif</span>
      <% } %>
    </div>
  </div>

  <!-- System Monitor -->
  <div class="grid grid-cols-4 gap-2.5" id="system-monitor">
    <!-- Active Streams -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-broadcast text-primary text-sm"></i>
      </div>
      <div>
        <div class="text-lg font-bold text-slate-800 leading-none" id="monitor-active-streams"><%= liveStreams %></div>
        <div class="text-[11px] text-slate-400 mt-0.5">Active Streams</div>
      </div>
    </div>

    <!-- CPU Usage -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3">
      <div class="flex items-center justify-between mb-1.5">
        <span class="text-[11px] font-medium text-slate-500">CPU</span>
        <span class="text-[11px] font-bold text-slate-700"><span id="monitor-cpu">--</span>%</span>
      </div>
      <div class="w-full bg-slate-100 rounded-full h-1">
        <div id="monitor-cpu-bar" class="h-1 rounded-full bg-primary transition-all duration-500" style="width: 0%"></div>
      </div>
    </div>

    <!-- Memory -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3">
      <div class="flex items-center justify-between mb-1.5">
        <span class="text-[11px] font-medium text-slate-500">Memory</span>
        <span class="text-[11px] font-bold text-slate-700"><span id="monitor-mem-used">--</span></span>
      </div>
      <div class="w-full bg-slate-100 rounded-full h-1">
        <div id="monitor-mem-bar" class="h-1 rounded-full bg-violet-400 transition-all duration-500" style="width: 0%"></div>
      </div>
      <div class="text-[10px] text-slate-300 mt-1">/ <span id="monitor-mem-total">--</span></div>
    </div>

    <!-- Internet -->
    <div class="bg-white rounded-lg border border-slate-200 px-3.5 py-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center flex-shrink-0">
        <i class="ti ti-wifi text-primary text-sm"></i>
      </div>
      <div class="text-[11px] space-y-0.5">
        <div class="flex items-center gap-1.5">
          <span class="text-slate-300">↑</span>
          <span class="font-semibold text-emerald-500" id="monitor-upload">--</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="text-slate-300">↓</span>
          <span class="font-semibold text-sky-500" id="monitor-download">--</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      async function refreshSystemStats() {
        try {
          const res = await fetch('/api/system-stats');
          if (!res.ok) return;
          const d = await res.json();
          const cpu = document.getElementById('monitor-cpu');
          const cpuBar = document.getElementById('monitor-cpu-bar');
          if (cpu) cpu.textContent = d.cpu.usage;
          if (cpuBar) cpuBar.style.width = d.cpu.usage + '%';
          const memUsed = document.getElementById('monitor-mem-used');
          const memTotal = document.getElementById('monitor-mem-total');
          const memBar = document.getElementById('monitor-mem-bar');
          if (memUsed) memUsed.textContent = d.memory.used;
          if (memTotal) memTotal.textContent = d.memory.total;
          if (memBar) memBar.style.width = d.memory.usagePercent + '%';
          const ul = document.getElementById('monitor-upload');
          const dl = document.getElementById('monitor-download');
          if (ul) ul.textContent = d.network.uploadFormatted;
          if (dl) dl.textContent = d.network.downloadFormatted;
        } catch(e) {}
      }
      refreshSystemStats();
      setInterval(refreshSystemStats, 3000);
    })();
  </script>

  <!-- Streaming Status -->
  <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-slate-800">Streaming Status</h2>
      <div class="flex items-center gap-2">
        <span id="bulk-action-bar" class="hidden items-center gap-2">
          <span class="text-xs text-slate-500" id="bulk-count">0 dipilih</span>
          <button onclick="bulkAction('stop')" class="text-xs px-2 py-1 bg-amber-100 text-amber-700 rounded-lg hover:bg-amber-200 transition-colors"><i class="ti ti-player-stop text-xs mr-1"></i>Stop</button>
          <button onclick="bulkAction('delete')" class="text-xs px-2 py-1 bg-red-100 text-red-600 rounded-lg hover:bg-red-200 transition-colors"><i class="ti ti-trash text-xs mr-1"></i>Hapus</button>
          <button onclick="clearBulk()" class="text-xs text-slate-400 hover:text-slate-600"><i class="ti ti-x"></i></button>
        </span>
        <a href="/schedule" class="text-xs text-primary hover:text-sky-700 transition-colors flex items-center gap-1"><i class="ti ti-calendar-event text-xs"></i> Jadwal</a>
        <a href="/rotations" class="text-xs text-primary hover:text-sky-700 transition-colors">Kelola Semua →</a>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full" id="overview-streams-table">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2.5 w-8"><input type="checkbox" id="bulk-select-all" onchange="toggleBulkAll(this)" class="rounded border-slate-300"></th>
            <th class="px-4 py-2.5 text-left text-[11px] font-medium text-slate-400 uppercase tracking-wider">Stream</th>
            <th class="px-4 py-2.5 text-left text-[11px] font-medium text-slate-400 uppercase tracking-wider">Platform</th>
            <th class="px-4 py-2.5 text-left text-[11px] font-medium text-slate-400 uppercase tracking-wider">Schedule</th>
            <th class="px-4 py-2.5 text-left text-[11px] font-medium text-slate-400 uppercase tracking-wider">Status</th>
            <th class="px-4 py-2.5 text-right text-[11px] font-medium text-slate-400 uppercase tracking-wider">Aksi</th>
          </tr>
        </thead>
        <tbody id="overview-streams-body" class="divide-y divide-slate-50">
          <tr>
            <td colspan="5" class="px-4 py-8 text-center">
              <i class="ti ti-loader animate-spin text-xl text-slate-300"></i>
              <p class="text-slate-400 text-xs mt-2">Memuat streams...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Upcoming Streams Widget -->
  <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
      <div>
        <h2 class="text-sm font-semibold text-slate-800">Jadwal Terdekat</h2>
        <p class="text-[11px] text-slate-400">Stream terjadwal dalam 24 jam ke depan</p>
      </div>
      <a href="/schedule" class="text-xs text-primary hover:underline flex items-center gap-1"><i class="ti ti-calendar-event text-xs"></i> Semua Jadwal</a>
    </div>
    <div id="upcoming-streams-list">
      <div class="flex items-center justify-center py-6 text-slate-300"><i class="ti ti-loader animate-spin text-xl"></i></div>
    </div>
  </div>

  <!-- YouTube Channel Info (only if connected) -->
  <% if (youtubeConnected) { %>
  <div class="bg-white rounded-lg border border-slate-200 px-4 py-3 flex items-center gap-3">
    <% if (youtubeChannelThumbnail) { %>
    <img src="<%= youtubeChannelThumbnail %>" alt="Channel" class="w-8 h-8 rounded-full">
    <% } else { %>
    <div class="w-8 h-8 rounded-full bg-red-50 flex items-center justify-center">
      <i class="ti ti-brand-youtube text-red-500 text-base"></i>
    </div>
    <% } %>
    <div>
      <div class="text-sm font-medium text-slate-800"><%= youtubeChannelName || 'YouTube Channel' %></div>
      <div class="text-[11px] text-slate-400"><%= youtubeSubscriberCount %> subscribers</div>
    </div>
    <span class="ml-auto inline-flex items-center gap-1 px-2 py-1 rounded-full text-[10px] font-medium bg-green-50 text-green-600">
      <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
      Connected
    </span>
  </div>
  <% } %>

</div>

<script>
(function() {
  const csrfToken = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
  let selectedIds = new Set();

  function getPlatformIcon(platform) {
    const map = { 'YouTube': 'brand-youtube', 'Facebook': 'brand-facebook', 'Twitch': 'brand-twitch', 'TikTok': 'brand-tiktok', 'Instagram': 'brand-instagram', 'Shopee Live': 'shopping-bag', 'Restream.io': 'live-photo' };
    return map[platform] || 'broadcast';
  }
  function getPlatformColor(platform) {
    const map = { 'YouTube': 'text-red-500', 'Facebook': 'text-blue-500', 'Twitch': 'text-purple-500', 'TikTok': 'text-slate-800', 'Instagram': 'text-pink-500', 'Shopee Live': 'text-orange-500' };
    return map[platform] || 'text-slate-500';
  }
  function formatSchedule(stream) {
    if (!stream.schedule_time && !stream.end_time) return '<span class="text-slate-300">—</span>';
    let html = '';
    if (stream.schedule_time) {
      const d = new Date(stream.schedule_time);
      html += '<div class="text-[11px] text-slate-600">' + d.toLocaleString('en-US', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit', hour12:false }) + '</div>';
    }
    if (stream.end_time) {
      const d = new Date(stream.end_time);
      html += '<div class="text-[11px] text-slate-400">→ ' + d.toLocaleString('en-US', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit', hour12:false }) + '</div>';
    }
    return html;
  }
  function getStatusBadge(status) {
    if (status === 'live') return '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-red-50 text-red-600"><span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>Live</span>';
    if (status === 'scheduled') return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-yellow-50 text-yellow-600">Scheduled</span>';
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-slate-100 text-slate-400">Offline</span>';
  }
  function getActions(stream) {
    let html = '<div class="flex items-center justify-end gap-1">';
    if (stream.status === 'live') {
      html += `<button onclick="ovStopStream('${stream.id}')" class="p-1 rounded hover:bg-red-50 text-red-400 transition-colors" title="Stop"><i class="ti ti-player-stop text-xs"></i></button>`;
      html += `<button onclick="ovRestartStream('${stream.id}')" class="p-1 rounded hover:bg-amber-50 text-amber-500 transition-colors" title="Restart"><i class="ti ti-refresh text-xs"></i></button>`;
    } else {
      html += `<button onclick="ovStartStream('${stream.id}')" class="p-1 rounded hover:bg-green-50 text-green-500 transition-colors" title="Start"><i class="ti ti-player-play text-xs"></i></button>`;
    }
    html += `<button onclick="ovDuplicateStream('${stream.id}')" class="p-1 rounded hover:bg-sky-50 text-sky-400 transition-colors" title="Duplikat"><i class="ti ti-copy text-xs"></i></button>`;
    html += `<a href="/rotations" class="p-1 rounded hover:bg-slate-100 text-slate-400 transition-colors" title="Edit"><i class="ti ti-pencil text-xs"></i></a>`;
    html += '</div>';
    return html;
  }

  function updateBulkBar() {
    const bar = document.getElementById('bulk-action-bar');
    const countEl = document.getElementById('bulk-count');
    if (selectedIds.size > 0) {
      bar.classList.remove('hidden');
      bar.classList.add('flex');
      countEl.textContent = `${selectedIds.size} dipilih`;
    } else {
      bar.classList.add('hidden');
      bar.classList.remove('flex');
    }
  }

  window.toggleBulkAll = function(cb) {
    document.querySelectorAll('.bulk-cb').forEach(el => {
      el.checked = cb.checked;
      if (cb.checked) selectedIds.add(el.dataset.id);
      else selectedIds.delete(el.dataset.id);
    });
    updateBulkBar();
  };
  window.toggleBulkOne = function(cb) {
    if (cb.checked) selectedIds.add(cb.dataset.id);
    else selectedIds.delete(cb.dataset.id);
    updateBulkBar();
  };
  window.clearBulk = function() {
    selectedIds.clear();
    document.querySelectorAll('.bulk-cb').forEach(el => el.checked = false);
    const all = document.getElementById('bulk-select-all');
    if (all) all.checked = false;
    updateBulkBar();
  };
  window.bulkAction = async function(action) {
    if (selectedIds.size === 0) return;
    const ids = Array.from(selectedIds);
    const confirmMsg = action === 'delete'
      ? `Hapus ${ids.length} stream? Tindakan ini tidak bisa dibatalkan.`
      : `Stop ${ids.length} stream yang sedang live?`;
    if (!confirm(confirmMsg)) return;
    try {
      const res = await fetch('/api/streams/bulk-action', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
        body: JSON.stringify({ action, ids })
      });
      const data = await res.json();
      if (data.success) {
        clearBulk();
        loadOverviewStreams();
      } else {
        alert(data.error || 'Gagal melakukan aksi');
      }
    } catch(e) { alert('Error: ' + e.message); }
  };

  async function loadOverviewStreams() {
    try {
      const res = await fetch('/api/streams');
      if (!res.ok) return;
      const data = await res.json();
      const streams = data.streams || [];
      const tbody = document.getElementById('overview-streams-body');
      if (!tbody) return;

      if (streams.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center">
          <i class="ti ti-broadcast-off text-3xl text-slate-200 mb-2"></i>
          <p class="text-slate-400 text-xs">Belum ada stream</p>
          <a href="/rotations" class="inline-flex items-center gap-1 mt-2 text-primary text-xs font-medium hover:text-sky-700"><i class="ti ti-plus"></i> Buat Stream</a>
        </td></tr>`;
        return;
      }

      const liveCount = streams.filter(s => s.status === 'live').length;
      const el = document.getElementById('monitor-active-streams');
      if (el) el.textContent = liveCount;

      tbody.innerHTML = streams.map(s => `
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-3 py-2.5 w-8"><input type="checkbox" class="bulk-cb rounded border-slate-300" data-id="${s.id}" onchange="toggleBulkOne(this)"></td>
          <td class="px-4 py-2.5">
            <div class="text-xs font-medium text-slate-800 truncate max-w-[160px]">${s.title || 'Untitled'}</div>
            ${s.notes ? `<div class="text-[10px] text-slate-400 truncate max-w-[160px] mt-0.5">${s.notes}</div>` : ''}
          </td>
          <td class="px-4 py-2.5">
            <div class="flex items-center gap-1">
              <i class="ti ti-${getPlatformIcon(s.platform)} ${getPlatformColor(s.platform)} text-sm"></i>
              <span class="text-xs text-slate-500">${s.platform || 'Custom'}</span>
            </div>
          </td>
          <td class="px-4 py-2.5">${formatSchedule(s)}</td>
          <td class="px-4 py-2.5">${getStatusBadge(s.status)}</td>
          <td class="px-4 py-2.5">${getActions(s)}</td>
        </tr>
      `).join('');
    } catch(e) {
      console.error('Error loading streams:', e);
    }
  }

  window.ovStartStream = async function(id) {
    try {
      const res = await fetch(`/api/streams/${id}/start`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken }
      });
      const data = await res.json();
      if (data.success) { loadOverviewStreams(); }
      else { alert(data.error || 'Failed to start stream'); }
    } catch(e) { alert('Error starting stream'); }
  };
  window.ovStopStream = async function(id) {
    if (!confirm('Stop this stream?')) return;
    try {
      const res = await fetch(`/api/streams/${id}/stop`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken }
      });
      const data = await res.json();
      if (data.success) { loadOverviewStreams(); }
      else { alert(data.error || 'Failed to stop stream'); }
    } catch(e) { alert('Error stopping stream'); }
  };
  window.ovRestartStream = async function(id) {
    if (!confirm('Restart stream ini? Stream akan di-stop lalu otomatis mulai ulang.')) return;
    try {
      const res = await fetch(`/api/streams/${id}/restart`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken }
      });
      const data = await res.json();
      if (data.success) { setTimeout(loadOverviewStreams, 3000); }
      else { alert(data.error || 'Gagal restart stream'); }
    } catch(e) { alert('Error restarting stream'); }
  };
  window.ovDuplicateStream = async function(id) {
    try {
      const res = await fetch(`/api/streams/${id}/duplicate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken }
      });
      const data = await res.json();
      if (data.success) {
        loadOverviewStreams();
        const msg = document.createElement('div');
        msg.className = 'fixed bottom-4 right-4 bg-emerald-600 text-white text-xs px-4 py-2 rounded-lg shadow-lg z-50 flex items-center gap-2';
        msg.innerHTML = '<i class="ti ti-check"></i> Stream berhasil diduplikat!';
        document.body.appendChild(msg);
        setTimeout(() => msg.remove(), 3000);
      } else { alert(data.error || 'Gagal menduplikat stream'); }
    } catch(e) { alert('Error: ' + e.message); }
  };

  // Upcoming Streams Widget
  async function loadUpcomingStreams() {
    const el = document.getElementById('upcoming-streams-list');
    if (!el) return;
    try {
      const res = await fetch('/api/schedule/upcoming?hours=24');
      const data = await res.json();
      if (!data.success || data.streams.length === 0) {
        el.innerHTML = '<div class="px-4 py-5 text-center text-slate-300 text-xs flex flex-col items-center gap-1"><i class="ti ti-calendar-off text-2xl mb-1"></i>Tidak ada jadwal dalam 24 jam ke depan</div>';
        return;
      }
      el.innerHTML = data.streams.map(s => {
        const d = new Date(s.schedule_time);
        const diff = d - new Date();
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const timeUntil = diff < 0 ? 'Terlambat' : (h > 0 ? `${h}j ${m}m` : `${m} mnt`) + ' lagi';
        return `<div class="flex items-center gap-3 px-4 py-2.5 border-b border-slate-50 last:border-0 hover:bg-slate-50 transition-colors">
          <div class="flex-1 min-w-0">
            <div class="text-xs font-medium text-slate-800 truncate">${s.title || 'Untitled'}</div>
            <div class="text-[10px] text-slate-400">${s.platform || 'Custom'}</div>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-[11px] font-semibold text-slate-700">${d.toLocaleTimeString('id-ID', {hour:'2-digit',minute:'2-digit'})}</div>
            <div class="text-[10px] text-primary">${timeUntil}</div>
          </div>
        </div>`;
      }).join('');
    } catch(e) {
      el.innerHTML = '<div class="px-4 py-4 text-center text-slate-300 text-xs">Gagal memuat jadwal</div>';
    }
  }

  loadOverviewStreams();
  loadUpcomingStreams();
  setInterval(loadOverviewStreams, 10000);
  setInterval(loadUpcomingStreams, 60000);
})();
</script>

